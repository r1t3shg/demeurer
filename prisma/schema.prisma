// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

// Note that some adapters may set a maximum length for the String type by default, please ensure your strings are long
// enough when changing adapters.
// See https://www.prisma.io/docs/orm/reference/prisma-schema-reference#string for more information
datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Session {
  id                  String    @id
  shop                String
  state               String
  isOnline            Boolean   @default(false)
  scope               String?
  expires             DateTime?
  accessToken         String
  userId              BigInt?
  firstName           String?
  lastName            String?
  email               String?
  accountOwner        Boolean   @default(false)
  locale              String?
  collaborator        Boolean?  @default(false)
  emailVerified       Boolean?  @default(false)
  refreshToken        String?
  refreshTokenExpires DateTime?
}

// Editor source-of-truth for a page. `source` is a JSON tree (the editor's
// block model). Intentionally NOT normalized into separate columns — the
// editor schema will evolve frequently in early development and flattening
// would make migrations painful. SQLite stores Json as TEXT under the hood.
model Page {
  id                     String        @id @default(cuid())
  shop                   String
  title                  String
  type                   String // "landing" | "product"
  handle                 String // URL slug
  source                 Json // Editor's source-of-truth tree
  publishedAt            DateTime?
  themeId                String?
  // Set true by the `themes/publish` webhook when the merchant
  // switches their MAIN theme and this page's published themeId no
  // longer matches. Cleared on successful re-publish (which targets
  // the new MAIN) or by an explicit Dismiss action from the editor
  // banner. See `app/routes/webhooks.themes.publish.tsx`.
  themeMismatch          Boolean       @default(false)
  // Product page binding. Required at the application layer when
  // type === "product"; nullable in the schema so existing landing
  // pages stay valid.
  productId              String? // gid://shopify/Product/123
  productHandle          String? // cached handle for storefront URL routing
  // Captured ONCE at first successful publish to a product page —
  // the templateSuffix the bound product had BEFORE we set ours.
  // Used on unpublish to restore (instead of blanking, which could
  // clobber another app's template).
  previousTemplateSuffix String?
  createdAt              DateTime      @default(now())
  updatedAt              DateTime      @updatedAt
  versions               PageVersion[]
  publishes              Publish[]

  @@unique([shop, handle])
  @@index([shop])
}

// Append-only version history for a page. Cascade-deletes when the parent
// Page is deleted by the merchant from inside the app — but is intentionally
// preserved on app uninstall (see app/routes/webhooks.app.uninstalled.tsx).
model PageVersion {
  id        String   @id @default(cuid())
  pageId    String
  source    Json
  label     String?
  createdAt DateTime @default(now())
  page      Page     @relation(fields: [pageId], references: [id], onDelete: Cascade)

  @@index([pageId])
}

// Append-only record of every publish attempt that reached a terminal
// state (success or partial_failure). Lets the merchant audit history
// and powers the "first publish" onboarding gate.
//
// `drift_blocked` and `auth_error` outcomes are NOT recorded here —
// those abort before any write happens, so they're not "publish
// attempts" in the audit sense.
model Publish {
  id                    String   @id @default(cuid())
  shop                  String
  pageId                String
  themeId               String
  themeName             String
  status                String // "success" | "partial_failure"
  fileCount             Int // number of files actually written
  artifactSourceVersion Int // page.updatedAt.getTime() at compile time
  failedPaths           String? // JSON array of failed paths; null on success
  createdAt             DateTime @default(now())

  page Page @relation(fields: [pageId], references: [id], onDelete: Cascade)

  @@index([pageId, createdAt])
  @@index([shop])
}

// Memory of files Demeurer has written to a merchant's theme.
//   - Populated by segment 3's writer (Asset API mutation).
//   - Consumed by segment 2's drift detector (compile/drift.ts) to
//     classify modifications as "drifted" (theme changed since we
//     last wrote) vs "stale" (we have no record; treat as drift but
//     softer signal).
// `contentHash` is md5 hex (matches Shopify's `checksumMd5`) so drift
// comparison is a string equality check.
model ThemeWrite {
  id          String   @id @default(cuid())
  shop        String
  themeId     String
  path        String // e.g. "sections/demeurer-hero.liquid"
  contentHash String // md5 hex of what we wrote
  pageId      String? // null for shared section files (one per type, not per page)
  writtenAt   DateTime @default(now())

  @@unique([shop, themeId, path])
  @@index([shop, themeId])
  @@index([pageId])
}
