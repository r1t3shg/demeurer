// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

// Note that some adapters may set a maximum length for the String type by default, please ensure your strings are long
// enough when changing adapters.
// See https://www.prisma.io/docs/orm/reference/prisma-schema-reference#string for more information
datasource db {
  provider = "sqlite"
  url      = "file:dev.sqlite"
}

model Session {
  id            String    @id
  shop          String
  state         String
  isOnline      Boolean   @default(false)
  scope         String?
  expires       DateTime?
  accessToken   String
  userId        BigInt?
  firstName     String?
  lastName      String?
  email         String?
  accountOwner  Boolean   @default(false)
  locale        String?
  collaborator  Boolean?  @default(false)
  emailVerified Boolean?  @default(false)
  refreshToken        String?
  refreshTokenExpires DateTime?
}

// Editor source-of-truth for a page. `source` is a JSON tree (the editor's
// block model). Intentionally NOT normalized into separate columns — the
// editor schema will evolve frequently in early development and flattening
// would make migrations painful. SQLite stores Json as TEXT under the hood.
model Page {
  id          String        @id @default(cuid())
  shop        String
  title       String
  type        String        // "landing" | "product"
  handle      String        // URL slug
  source      Json          // Editor's source-of-truth tree
  publishedAt DateTime?
  themeId     String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  versions    PageVersion[]

  @@unique([shop, handle])
  @@index([shop])
}

// Append-only version history for a page. Cascade-deletes when the parent
// Page is deleted by the merchant from inside the app — but is intentionally
// preserved on app uninstall (see app/routes/webhooks.app.uninstalled.tsx).
model PageVersion {
  id        String   @id @default(cuid())
  pageId    String
  source    Json
  label     String?
  createdAt DateTime @default(now())
  page      Page     @relation(fields: [pageId], references: [id], onDelete: Cascade)

  @@index([pageId])
}

// Memory of files Demeurer has written to a merchant's theme.
//   - Populated by segment 3's writer (Asset API mutation).
//   - Consumed by segment 2's drift detector (compile/drift.ts) to
//     classify modifications as "drifted" (theme changed since we
//     last wrote) vs "stale" (we have no record; treat as drift but
//     softer signal).
// `contentHash` is md5 hex (matches Shopify's `checksumMd5`) so drift
// comparison is a string equality check.
model ThemeWrite {
  id          String   @id @default(cuid())
  shop        String
  themeId     String
  path        String   // e.g. "sections/demeurer-hero.liquid"
  contentHash String   // md5 hex of what we wrote
  pageId      String?  // null for shared section files (one per type, not per page)
  writtenAt   DateTime @default(now())

  @@unique([shop, themeId, path])
  @@index([shop, themeId])
  @@index([pageId])
}
