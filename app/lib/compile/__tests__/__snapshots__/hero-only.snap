  "artifact": {
    "files": [
      {
        "content": "{%- liquid\n  assign scope = section.settings.scope_id | default: 'demeurer-hero'\n-%}\n{%- style -%}\n  {{ section.settings.mobile_styles }}\n  {%- if section.settings.tablet_styles != blank -%}\n    @media (min-width: 768px) { .{{ scope }} { {{ section.settings.tablet_styles }} } }\n  {%- endif -%}\n  {%- if section.settings.desktop_styles != blank -%}\n    @media (min-width: 1280px) { .{{ scope }} { {{ section.settings.desktop_styles }} } }\n  {%- endif -%}\n  {{ section.settings.visibility_styles }}\n{%- endstyle -%}\n\n<section class=\"{{ scope }} demeurer-section demeurer-hero demeurer-hero--{{ section.settings.alignment }}\" style=\"position: relative; overflow: hidden; min-height: 240px;\">\n  {%- if section.settings.backgroundImage != blank -%}\n    <div class=\"demeurer-hero__bg\" style=\"position: absolute; inset: 0; z-index: 0; background-image: url('{{ section.settings.backgroundImage | image_url: width: 2400 }}'); background-size: cover; background-position: center;\" role=\"presentation\"></div>\n    <div class=\"demeurer-hero__overlay\" style=\"position: absolute; inset: 0; z-index: 1; background-color: {{ section.settings.overlayColor }}; pointer-events: none;\" aria-hidden=\"true\"></div>\n  {%- endif -%}\n\n  <div class=\"demeurer-hero__content\" style=\"position: relative; z-index: 2; max-width: 720px; margin-inline: auto;\">\n    {%- if section.settings.heading != blank -%}\n      <h1 class=\"demeurer-hero__heading\">{{ section.settings.heading | escape }}</h1>\n    {%- endif -%}\n    {%- if section.settings.subheading != blank -%}\n      <div class=\"demeurer-hero__subheading\">{{ section.settings.subheading }}</div>\n    {%- endif -%}\n    {%- if section.settings.ctaLabel != blank -%}\n      <a class=\"demeurer-hero__cta\" href=\"{{ section.settings.ctaUrl | default: '#' }}\">{{ section.settings.ctaLabel | escape }}</a>\n    {%- endif -%}\n  </div>\n</section>\n\n{% schema %}\n{\n  \"class\": \"demeurer-section demeurer-hero\",\n  \"name\": \"Demeurer Hero\",\n  \"presets\": [\n    {\n      \"name\": \"Demeurer Hero\"\n    }\n  ],\n  \"settings\": [\n    {\n      \"id\": \"heading\",\n      \"label\": \"Heading\",\n      \"type\": \"textarea\"\n    },\n    {\n      \"id\": \"subheading\",\n      \"label\": \"Subheading\",\n      \"type\": \"richtext\"\n    },\n    {\n      \"id\": \"backgroundImage\",\n      \"label\": \"Background image\",\n      \"type\": \"image_picker\"\n    },\n    {\n      \"default\": \"center\",\n      \"id\": \"alignment\",\n      \"label\": \"Text alignment\",\n      \"options\": [\n        {\n          \"label\": \"Left\",\n          \"value\": \"left\"\n        },\n        {\n          \"label\": \"Center\",\n          \"value\": \"center\"\n        }\n      ],\n      \"type\": \"select\"\n    },\n    {\n      \"id\": \"ctaUrl\",\n      \"label\": \"CTA link\",\n      \"type\": \"url\"\n    },\n    {\n      \"id\": \"ctaLabel\",\n      \"label\": \"CTA button text\",\n      \"type\": \"textarea\"\n    },\n    {\n      \"id\": \"overlayColor\",\n      \"label\": \"Image overlay\",\n      \"type\": \"color\"\n    },\n    {\n      \"id\": \"padding_top\",\n      \"label\": \"Section padding (top)\",\n      \"type\": \"number\"\n    },\n    {\n      \"id\": \"padding_right\",\n      \"label\": \"Section padding (right)\",\n      \"type\": \"number\"\n    },\n    {\n      \"id\": \"padding_bottom\",\n      \"label\": \"Section padding (bottom)\",\n      \"type\": \"number\"\n    },\n    {\n      \"id\": \"padding_left\",\n      \"label\": \"Section padding (left)\",\n      \"type\": \"number\"\n    },\n    {\n      \"id\": \"scope_id\",\n      \"info\": \"\",\n      \"label\": \"Scope id\",\n      \"type\": \"text\"\n    },\n    {\n      \"id\": \"mobile_styles\",\n      \"info\": \"\",\n      \"label\": \"Mobile styles\",\n      \"type\": \"textarea\"\n    },\n    {\n      \"id\": \"tablet_styles\",\n      \"info\": \"\",\n      \"label\": \"Tablet styles\",\n      \"type\": \"textarea\"\n    },\n    {\n      \"id\": \"desktop_styles\",\n      \"info\": \"\",\n      \"label\": \"Desktop styles\",\n      \"type\": \"textarea\"\n    },\n    {\n      \"id\": \"visibility_styles\",\n      \"info\": \"\",\n      \"label\": \"Visibility styles\",\n      \"type\": \"textarea\"\n    }\n  ],\n  \"tag\": \"section\"\n}\n{% endschema %}\n",
        "contentHash": "b3564a88f280f61edbecc8e1811381df9811416e1a457f9ab11e115bc4b9d77c",
        "path": "sections/demeurer-hero.liquid",
        "purpose": "section",
        "sectionType": "hero"
      },
      {
        "content": "{\n  \"order\": [\n    \"main-blk_hero\"\n  ],\n  \"sections\": {\n    \"main-blk_hero\": {\n      \"settings\": {\n        \"alignment\": \"center\",\n        \"backgroundImage\": \"\",\n        \"ctaLabel\": \"Shop now\",\n        \"ctaUrl\": \"/collections/all\",\n        \"desktop_styles\": \"\",\n        \"heading\": \"Welcome home\",\n        \"mobile_styles\": \".demeurer-hero-blk_hero_aaaaaaaa {\\n  padding: 96px 24px 96px 24px;\\n  text-align: center;\\n}\",\n        \"overlayColor\": \"#00000040\",\n        \"padding_bottom\": 96,\n        \"padding_left\": 24,\n        \"padding_right\": 24,\n        \"padding_top\": 96,\n        \"scope_id\": \"demeurer-hero-blk_hero_aaaaaaaa\",\n        \"subheading\": \"<p>Subhead.</p>\",\n        \"tablet_styles\": \"\",\n        \"visibility_styles\": \"\"\n      },\n      \"type\": \"demeurer-hero\"\n    }\n  }\n}\n",
