      {
        "content": "{%- liquid\n  assign scope = section.settings.scope_id | default: 'demeurer-hero'\n-%}\n{%- style -%}\n  {{ section.settings.mobile_styles }}\n  {%- if section.settings.tablet_styles != blank -%}\n    @media (min-width: 768px) { .{{ scope }} { {{ section.settings.tablet_styles }} } }\n  {%- endif -%}\n  {%- if section.settings.desktop_styles != blank -%}\n    @media (min-width: 1280px) { .{{ scope }} { {{ section.settings.desktop_styles }} } }\n  {%- endif -%}\n  {{ section.settings.visibility_styles }}\n{%- endstyle -%}\n\n{%- if section.settings.bound_variant_ids != blank -%}\n  {%- assign current_variant_id = product.selected_or_first_available_variant.id | append: '' -%}\n  {%- assign bound_ids = section.settings.bound_variant_ids | split: ',' -%}\n  {%- assign should_render = false -%}\n  {%- for vid in bound_ids -%}\n    {%- assign normalized = vid | strip -%}\n    {%- if normalized == current_variant_id -%}\n      {%- assign should_render = true -%}\n    {%- endif -%}\n  {%- endfor -%}\n  {%- if should_render -%}\n<section class=\"{{ scope }} demeurer-section demeurer-hero demeurer-hero--{{ section.settings.alignment }}\" style=\"position: relative; overflow: hidden; min-height: 240px;\">\n  {%- if section.settings.backgroundImage != blank -%}\n    <div class=\"demeurer-hero__bg\" style=\"position: absolute; inset: 0; z-index: 0; background-image: url('{{ section.settings.backgroundImage | image_url: width: 2400 }}'); background-size: cover; background-position: center;\" role=\"presentation\"></div>\n    <div class=\"demeurer-hero__overlay\" style=\"position: absolute; inset: 0; z-index: 1; background-color: {{ section.settings.overlayColor }}; pointer-events: none;\" aria-hidden=\"true\"></div>\n  {%- endif -%}\n\n  <div class=\"demeurer-hero__content\" style=\"position: relative; z-index: 2; max-width: 720px; margin-inline: auto;\">\n    {%- if section.settings.heading != blank -%}\n      <h1 class=\"demeurer-hero__heading\">{{ section.settings.heading | escape }}</h1>\n    {%- endif -%}\n    {%- if section.settings.subheading != blank -%}\n      <div class=\"demeurer-hero__subheading\">{{ section.settings.subheading }}</div>\n    {%- endif -%}\n    {%- if section.settings.ctaLabel != blank -%}\n      <a class=\"demeurer-hero__cta\" href=\"{{ section.settings.ctaUrl | default: '#' }}\">{{ section.settings.ctaLabel | escape }}</a>\n    {%- endif -%}\n  </div>\n</section>\n  {%- endif -%}\n{%- else -%}\n<section class=\"{{ scope }} demeurer-section demeurer-hero demeurer-hero--{{ section.settings.alignment }}\" style=\"position: relative; overflow: hidden; min-height: 240px;\">\n  {%- if section.settings.backgroundImage != blank -%}\n    <div class=\"demeurer-hero__bg\" style=\"position: absolute; inset: 0; z-index: 0; background-image: url('{{ section.settings.backgroundImage | image_url: width: 2400 }}'); background-size: cover; background-position: center;\" role=\"presentation\"></div>\n    <div class=\"demeurer-hero__overlay\" style=\"position: absolute; inset: 0; z-index: 1; background-color: {{ section.settings.overlayColor }}; pointer-events: none;\" aria-hidden=\"true\"></div>\n  {%- endif -%}\n\n  <div class=\"demeurer-hero__content\" style=\"position: relative; z-index: 2; max-width: 720px; margin-inline: auto;\">\n    {%- if section.settings.heading != blank -%}\n      <h1 class=\"demeurer-hero__heading\">{{ section.settings.heading | escape }}</h1>\n    {%- endif -%}\n    {%- if section.settings.subheading != blank -%}\n      <div class=\"demeurer-hero__subheading\">{{ section.settings.subheading }}</div>\n    {%- endif -%}\n    {%- if section.settings.ctaLabel != blank -%}\n      <a class=\"demeurer-hero__cta\" href=\"{{ section.settings.ctaUrl | default: '#' }}\">{{ section.settings.ctaLabel | escape }}</a>\n    {%- endif -%}\n  </div>\n</section>\n{%- endif -%}\n\n{% schema %}\n{\n  \"class\": \"demeurer-section demeurer-hero\",\n  \"name\": \"Demeurer Hero\",\n  \"presets\": [\n    {\n      \"name\": \"Demeurer Hero\"\n    }\n  ],\n  \"settings\": [\n    {\n      \"id\": \"heading\",\n      \"label\": \"Heading\",\n      \"type\": \"textarea\"\n    },\n    {\n      \"id\": \"subheading\",\n      \"label\": \"Subheading\",\n      \"type\": \"richtext\"\n    },\n    {\n      \"id\": \"backgroundImage\",\n      \"label\": \"Background image\",\n      \"type\": \"image_picker\"\n    },\n    {\n      \"default\": \"center\",\n      \"id\": \"alignment\",\n      \"label\": \"Text alignment\",\n      \"options\": [\n        {\n          \"label\": \"Left\",\n          \"value\": \"left\"\n        },\n        {\n          \"label\": \"Center\",\n          \"value\": \"center\"\n        }\n      ],\n      \"type\": \"select\"\n    },\n    {\n      \"id\": \"ctaUrl\",\n      \"label\": \"CTA link\",\n      \"type\": \"url\"\n    },\n    {\n      \"id\": \"ctaLabel\",\n      \"label\": \"CTA button text\",\n      \"type\": \"textarea\"\n    },\n    {\n      \"id\": \"overlayColor\",\n      \"label\": \"Image overlay\",\n      \"type\": \"color\"\n    },\n    {\n      \"id\": \"padding_top\",\n      \"label\": \"Section padding (top)\",\n      \"type\": \"number\"\n    },\n    {\n      \"id\": \"padding_right\",\n      \"label\": \"Section padding (right)\",\n      \"type\": \"number\"\n    },\n    {\n      \"id\": \"padding_bottom\",\n      \"label\": \"Section padding (bottom)\",\n      \"type\": \"number\"\n    },\n    {\n      \"id\": \"padding_left\",\n      \"label\": \"Section padding (left)\",\n      \"type\": \"number\"\n    },\n    {\n      \"id\": \"scope_id\",\n      \"info\": \"\",\n      \"label\": \"Scope id\",\n      \"type\": \"text\"\n    },\n    {\n      \"id\": \"mobile_styles\",\n      \"info\": \"\",\n      \"label\": \"Mobile styles\",\n      \"type\": \"textarea\"\n    },\n    {\n      \"id\": \"tablet_styles\",\n      \"info\": \"\",\n      \"label\": \"Tablet styles\",\n      \"type\": \"textarea\"\n    },\n    {\n      \"id\": \"desktop_styles\",\n      \"info\": \"\",\n      \"label\": \"Desktop styles\",\n      \"type\": \"textarea\"\n    },\n    {\n      \"id\": \"visibility_styles\",\n      \"info\": \"\",\n      \"label\": \"Visibility styles\",\n      \"type\": \"textarea\"\n    },\n    {\n      \"id\": \"bound_variant_ids\",\n      \"info\": \"\",\n      \"label\": \"Bound variant ids\",\n      \"type\": \"text\"\n    }\n  ],\n  \"tag\": \"section\"\n}\n{% endschema %}\n",
        "contentHash": "f1a009f58be7f4d8e6c27dd464b000ab0a1490917625130fa98ec47e47222979",
        "path": "sections/demeurer-hero.liquid",
        "purpose": "section",
        "sectionType": "hero"
      },
      {
        "content": "{%- liquid\n  assign scope = section.settings.scope_id | default: 'demeurer-image-text'\n-%}\n{%- style -%}\n  {{ section.settings.mobile_styles }}\n  {%- if section.settings.tablet_styles != blank -%}\n    @media (min-width: 768px) { .{{ scope }} { {{ section.settings.tablet_styles }} } }\n  {%- endif -%}\n  {%- if section.settings.desktop_styles != blank -%}\n    @media (min-width: 1280px) { .{{ scope }} { {{ section.settings.desktop_styles }} } }\n  {%- endif -%}\n  {{ section.settings.visibility_styles }}\n{%- endstyle -%}\n\n{%- if section.settings.bound_variant_ids != blank -%}\n  {%- assign current_variant_id = product.selected_or_first_available_variant.id | append: '' -%}\n  {%- assign bound_ids = section.settings.bound_variant_ids | split: ',' -%}\n  {%- assign should_render = false -%}\n  {%- for vid in bound_ids -%}\n    {%- assign normalized = vid | strip -%}\n    {%- if normalized == current_variant_id -%}\n      {%- assign should_render = true -%}\n    {%- endif -%}\n  {%- endfor -%}\n  {%- if should_render -%}\n{%- liquid\n  assign image_pct = section.settings.imageWidth | plus: 0\n  assign text_pct = 100 | minus: image_pct\n  assign flex_dir = 'row'\n  if section.settings.imagePosition == 'right'\n    assign flex_dir = 'row-reverse'\n  endif\n-%}\n\n<section class=\"{{ scope }} demeurer-section demeurer-image-text\">\n  <div class=\"demeurer-image-text__inner\" style=\"max-width: 1200px; margin-inline: auto; display: flex; flex-direction: {{ flex_dir }}; flex-wrap: wrap; align-items: center; gap: 48px;\">\n    <div class=\"demeurer-image-text__image\" style=\"flex: 1 1 {{ image_pct }}%; min-width: 240px;\">\n      {%- if section.settings.image != blank -%}\n        {%- assign alt = section.settings.imageAlt | default: section.settings.image.alt | default: '' -%}\n        {{ section.settings.image | image_url: width: 1600 | image_tag:\n          loading: 'lazy',\n          widths: '400, 600, 800, 1200, 1600',\n          sizes: '(min-width: 768px) 50vw, 100vw',\n          alt: alt,\n          class: 'demeurer-image-text__img',\n          style: 'width: 100%; height: auto; border-radius: 8px; display: block;'\n        }}\n      {%- else -%}\n        <div style=\"aspect-ratio: 4 / 3; background: #e5e7eb; border-radius: 8px;\"></div>\n      {%- endif -%}\n    </div>\n    <div class=\"demeurer-image-text__text\" style=\"flex: 1 1 {{ text_pct }}%; min-width: 240px;\">\n      {%- if section.settings.heading != blank -%}\n        <h2 class=\"demeurer-image-text__heading\" style=\"margin: 0;\">{{ section.settings.heading | escape }}</h2>\n      {%- endif -%}\n      {%- if section.settings.body != blank -%}\n        <div class=\"demeurer-image-text__body\" style=\"margin-top: 16px; line-height: 1.6;\">{{ section.settings.body }}</div>\n      {%- endif -%}\n      {%- if section.settings.ctaLabel != blank -%}\n        <a class=\"demeurer-image-text__cta\" href=\"{{ section.settings.ctaUrl | default: '#' }}\" style=\"display: inline-block; margin-top: 24px; padding: 12px 24px; background: var(--demeurer-accent, #1a73e8); color: #fff; border-radius: 4px; text-decoration: none; font-weight: 600;\">{{ section.settings.ctaLabel | escape }}</a>\n      {%- endif -%}\n    </div>\n  </div>\n</section>\n  {%- endif -%}\n{%- else -%}\n{%- liquid\n  assign image_pct = section.settings.imageWidth | plus: 0\n  assign text_pct = 100 | minus: image_pct\n  assign flex_dir = 'row'\n  if section.settings.imagePosition == 'right'\n    assign flex_dir = 'row-reverse'\n  endif\n-%}\n\n<section class=\"{{ scope }} demeurer-section demeurer-image-text\">\n  <div class=\"demeurer-image-text__inner\" style=\"max-width: 1200px; margin-inline: auto; display: flex; flex-direction: {{ flex_dir }}; flex-wrap: wrap; align-items: center; gap: 48px;\">\n    <div class=\"demeurer-image-text__image\" style=\"flex: 1 1 {{ image_pct }}%; min-width: 240px;\">\n      {%- if section.settings.image != blank -%}\n        {%- assign alt = section.settings.imageAlt | default: section.settings.image.alt | default: '' -%}\n        {{ section.settings.image | image_url: width: 1600 | image_tag:\n          loading: 'lazy',\n          widths: '400, 600, 800, 1200, 1600',\n          sizes: '(min-width: 768px) 50vw, 100vw',\n          alt: alt,\n          class: 'demeurer-image-text__img',\n          style: 'width: 100%; height: auto; border-radius: 8px; display: block;'\n        }}\n      {%- else -%}\n        <div style=\"aspect-ratio: 4 / 3; background: #e5e7eb; border-radius: 8px;\"></div>\n      {%- endif -%}\n    </div>\n    <div class=\"demeurer-image-text__text\" style=\"flex: 1 1 {{ text_pct }}%; min-width: 240px;\">\n      {%- if section.settings.heading != blank -%}\n        <h2 class=\"demeurer-image-text__heading\" style=\"margin: 0;\">{{ section.settings.heading | escape }}</h2>\n      {%- endif -%}\n      {%- if section.settings.body != blank -%}\n        <div class=\"demeurer-image-text__body\" style=\"margin-top: 16px; line-height: 1.6;\">{{ section.settings.body }}</div>\n      {%- endif -%}\n      {%- if section.settings.ctaLabel != blank -%}\n        <a class=\"demeurer-image-text__cta\" href=\"{{ section.settings.ctaUrl | default: '#' }}\" style=\"display: inline-block; margin-top: 24px; padding: 12px 24px; background: var(--demeurer-accent, #1a73e8); color: #fff; border-radius: 4px; text-decoration: none; font-weight: 600;\">{{ section.settings.ctaLabel | escape }}</a>\n      {%- endif -%}\n    </div>\n  </div>\n</section>\n{%- endif -%}\n\n{% schema %}\n{\n  \"class\": \"demeurer-section demeurer-image-text\",\n  \"name\": \"Demeurer Image + text\",\n  \"presets\": [\n    {\n      \"name\": \"Demeurer Image + text\"\n    }\n  ],\n  \"settings\": [\n    {\n      \"id\": \"image\",\n      \"label\": \"Image\",\n      \"type\": \"image_picker\"\n    },\n    {\n      \"id\": \"imageAlt\",\n      \"label\": \"Image alt text\",\n      \"type\": \"textarea\"\n    },\n    {\n      \"default\": \"left\",\n      \"id\": \"imagePosition\",\n      \"label\": \"Image position\",\n      \"options\": [\n        {\n          \"label\": \"Left\",\n          \"value\": \"left\"\n        },\n        {\n          \"label\": \"Right\",\n          \"value\": \"right\"\n        }\n      ],\n      \"type\": \"select\"\n    },\n    {\n      \"default\": \"50\",\n      \"id\": \"imageWidth\",\n      \"label\": \"Image width\",\n      \"options\": [\n        {\n          \"label\": \"40%\",\n          \"value\": \"40\"\n        },\n        {\n          \"label\": \"50%\",\n          \"value\": \"50\"\n        },\n        {\n          \"label\": \"60%\",\n          \"value\": \"60\"\n        }\n      ],\n      \"type\": \"select\"\n    },\n    {\n      \"id\": \"heading\",\n      \"label\": \"Heading\",\n      \"type\": \"textarea\"\n    },\n    {\n      \"id\": \"body\",\n      \"label\": \"Body\",\n      \"type\": \"richtext\"\n    },\n    {\n      \"id\": \"ctaLabel\",\n      \"label\": \"CTA label\",\n      \"type\": \"textarea\"\n    },\n    {\n      \"id\": \"ctaUrl\",\n      \"label\": \"CTA link\",\n      \"type\": \"url\"\n    },\n    {\n      \"id\": \"padding_top\",\n      \"label\": \"Section padding (top)\",\n      \"type\": \"number\"\n    },\n    {\n      \"id\": \"padding_right\",\n      \"label\": \"Section padding (right)\",\n      \"type\": \"number\"\n    },\n    {\n      \"id\": \"padding_bottom\",\n      \"label\": \"Section padding (bottom)\",\n      \"type\": \"number\"\n    },\n    {\n      \"id\": \"padding_left\",\n      \"label\": \"Section padding (left)\",\n      \"type\": \"number\"\n    },\n    {\n      \"id\": \"scope_id\",\n      \"info\": \"\",\n      \"label\": \"Scope id\",\n      \"type\": \"text\"\n    },\n    {\n      \"id\": \"mobile_styles\",\n      \"info\": \"\",\n      \"label\": \"Mobile styles\",\n      \"type\": \"textarea\"\n    },\n    {\n      \"id\": \"tablet_styles\",\n      \"info\": \"\",\n      \"label\": \"Tablet styles\",\n      \"type\": \"textarea\"\n    },\n    {\n      \"id\": \"desktop_styles\",\n      \"info\": \"\",\n      \"label\": \"Desktop styles\",\n      \"type\": \"textarea\"\n    },\n    {\n      \"id\": \"visibility_styles\",\n      \"info\": \"\",\n      \"label\": \"Visibility styles\",\n      \"type\": \"textarea\"\n    },\n    {\n      \"id\": \"bound_variant_ids\",\n      \"info\": \"\",\n      \"label\": \"Bound variant ids\",\n      \"type\": \"text\"\n    }\n  ],\n  \"tag\": \"section\"\n}\n{% endschema %}\n",
        "contentHash": "cae8fff91955828de6db08fc3eaa99fa303bc1a911db0b07d7cba8f130e5ae85",
        "path": "sections/demeurer-image-text.liquid",
        "purpose": "section",
        "sectionType": "image-text"
      },
      {
        "content": "{%- liquid\n  assign scope = section.settings.scope_id | default: 'demeurer-spacer'\n-%}\n{%- style -%}\n  {{ section.settings.mobile_styles }}\n  {%- if section.settings.tablet_styles != blank -%}\n    @media (min-width: 768px) { .{{ scope }} { {{ section.settings.tablet_styles }} } }\n  {%- endif -%}\n  {%- if section.settings.desktop_styles != blank -%}\n    @media (min-width: 1280px) { .{{ scope }} { {{ section.settings.desktop_styles }} } }\n  {%- endif -%}\n  {{ section.settings.visibility_styles }}\n{%- endstyle -%}\n\n{%- liquid\n  case section.settings.dividerWidth\n    when 'medium'\n      assign thickness = 2\n    when 'thick'\n      assign thickness = 4\n    else\n      assign thickness = 1\n  endcase\n-%}\n\n<section class=\"{{ scope }} demeurer-section demeurer-spacer\" style=\"height: {{ section.settings.height }}px; display: flex; align-items: center; justify-content: center;\">\n  {%- if section.settings.showDivider -%}\n    <hr style=\"width: 100%; max-width: 1024px; margin: 0; border: 0; border-top: {{ thickness }}px solid {{ section.settings.dividerColor }};\" />\n  {%- endif -%}\n</section>\n\n{% schema %}\n{\n  \"class\": \"demeurer-section demeurer-spacer\",\n  \"name\": \"Demeurer Spacer\",\n  \"presets\": [\n    {\n      \"name\": \"Demeurer Spacer\"\n    }\n  ],\n  \"settings\": [\n    {\n      \"id\": \"height\",\n      \"label\": \"Height (px)\",\n      \"type\": \"number\"\n    },\n    {\n      \"id\": \"showDivider\",\n      \"label\": \"Show divider line\",\n      \"type\": \"checkbox\"\n    },\n    {\n      \"id\": \"dividerColor\",\n      \"label\": \"Divider color\",\n      \"type\": \"color\"\n    },\n    {\n      \"default\": \"thin\",\n      \"id\": \"dividerWidth\",\n      \"label\": \"Divider thickness\",\n      \"options\": [\n        {\n          \"label\": \"Thin\",\n          \"value\": \"thin\"\n        },\n        {\n          \"label\": \"Medium\",\n          \"value\": \"medium\"\n        },\n        {\n          \"label\": \"Thick\",\n          \"value\": \"thick\"\n        }\n      ],\n      \"type\": \"select\"\n    },\n    {\n      \"id\": \"scope_id\",\n      \"info\": \"\",\n      \"label\": \"Scope id\",\n      \"type\": \"text\"\n    },\n    {\n      \"id\": \"mobile_styles\",\n      \"info\": \"\",\n      \"label\": \"Mobile styles\",\n      \"type\": \"textarea\"\n    },\n    {\n      \"id\": \"tablet_styles\",\n      \"info\": \"\",\n      \"label\": \"Tablet styles\",\n      \"type\": \"textarea\"\n    },\n    {\n      \"id\": \"desktop_styles\",\n      \"info\": \"\",\n      \"label\": \"Desktop styles\",\n      \"type\": \"textarea\"\n    },\n    {\n      \"id\": \"visibility_styles\",\n      \"info\": \"\",\n      \"label\": \"Visibility styles\",\n      \"type\": \"textarea\"\n    }\n  ],\n  \"tag\": \"section\"\n}\n{% endschema %}\n",
        "contentHash": "224c0acd43cd90fefef121a8a6d77c6e2429a905f6570324931a73735f381c67",
        "path": "sections/demeurer-spacer.liquid",
        "purpose": "section",
        "sectionType": "spacer"
      },
      {
        "content": "{\n  \"order\": [\n    \"main-blk_hero\",\n    \"main-blk_ctab\",\n    \"main-blk_imgt\",\n    \"main-blk_feat\",\n    \"main-blk_spac\"\n  ],\n  \"sections\": {\n    \"main-blk_ctab\": {\n      \"settings\": {\n        \"alignment\": \"center\",\n        \"background\": \"#1a1a1a\",\n        \"ctaLabel\": \"Sign up\",\n        \"ctaUrl\": \"/account/register\",\n        \"desktop_styles\": \"\",\n        \"heading\": \"Ready to get started?\",\n        \"mobile_styles\": \".demeurer-cta-band-blk_ctab_pppppppp {\\n  padding: 0;\\n  text-align: center;\\n  background: #1a1a1a;\\n}\",\n        \"padding_bottom\": 64,\n        \"padding_left\": 24,\n        \"padding_right\": 24,\n        \"padding_top\": 64,\n        \"scope_id\": \"demeurer-cta-band-blk_ctab_pppppppp\",\n        \"secondaryCtaLabel\": \"\",\n        \"secondaryCtaUrl\": \"\",\n        \"subheading\": \"<p>Free shipping on your first order. No surprises at checkout.</p>\",\n        \"tablet_styles\": \"  background: #0f172a !important;\",\n        \"visibility_styles\": \"\"\n      },\n      \"type\": \"demeurer-cta-band\"\n    },\n    \"main-blk_feat\": {\n      \"block_order\": [\n        \"features-0\",\n        \"features-1\",\n        \"features-2\"\n      ],\n      \"blocks\": {\n        \"features-0\": {\n          \"settings\": {\n            \"description\": \"<p>Orders placed before 2pm ship the same day from our warehouse.</p>\",\n            \"icon\": \"Zap\",\n            \"title\": \"Fast shipping\"\n          },\n          \"type\": \"features\"\n        },\n        \"features-1\": {\n          \"settings\": {\n            \"description\": \"<p>Not the right fit? Send it back within 30 days for a full refund.</p>\",\n            \"icon\": \"Shield\",\n            \"title\": \"30-day returns\"\n          },\n          \"type\": \"features\"\n        },\n        \"features-2\": {\n          \"settings\": {\n            \"description\": \"<p>Every product is sourced from makers we've worked with for years.</p>\",\n            \"icon\": \"Heart\",\n            \"title\": \"Made with care\"\n          },\n          \"type\": \"features\"\n        }\n      },\n      \"settings\": {\n        \"alignment\": \"left\",\n        \"desktop_styles\": \"  padding: 96px 32px 96px 32px !important;\",\n        \"heading\": \"Why choose us\",\n        \"layout\": \"grid-3\",\n        \"mobile_styles\": \".demeurer-feature-list-blk_feat_rrrrrrrr {\\n  padding: 0;\\n  text-align: center;\\n}\",\n        \"padding_bottom\": 64,\n        \"padding_left\": 24,\n        \"padding_right\": 24,\n        \"padding_top\": 64,\n        \"scope_id\": \"demeurer-feature-list-blk_feat_rrrrrrrr\",\n        \"subheading\": \"\",\n        \"tablet_styles\": \"\",\n        \"visibility_styles\": \"\"\n      },\n      \"type\": \"demeurer-feature-list\"\n    },\n    \"main-blk_hero\": {\n      \"settings\": {\n        \"alignment\": \"center\",\n        \"backgroundImage\": \"\",\n        \"bound_variant_ids\": \"\",\n        \"ctaLabel\": \"Shop now\",\n        \"ctaUrl\": \"/collections/all\",\n        \"desktop_styles\": \"  text-align: start !important;\",\n        \"heading\": \"Welcome to your store\",\n        \"mobile_styles\": \".demeurer-hero-blk_hero_oooooooo {\\n  padding: 0;\\n  text-align: center;\\n}\",\n        \"overlayColor\": \"#00000040\",\n        \"padding_bottom\": 96,\n        \"padding_left\": 24,\n        \"padding_right\": 24,\n        \"padding_top\": 96,\n        \"scope_id\": \"demeurer-hero-blk_hero_oooooooo\",\n        \"subheading\": \"<p>Your subheading here</p>\",\n        \"tablet_styles\": \"  padding: 120px 32px 120px 32px !important;\",\n        \"visibility_styles\": \"\"\n      },\n      \"type\": \"demeurer-hero\"\n    },\n    \"main-blk_imgt\": {\n      \"settings\": {\n        \"body\": \"<p>We started in a one-bedroom apartment with a sewing machine and a vision. Today, our pieces are worn in over thirty countries — but the makers, the materials, and the obsession with detail are exactly the same.</p>\",\n        \"bound_variant_ids\": \"\",\n        \"ctaLabel\": \"\",\n        \"ctaUrl\": \"\",\n        \"desktop_styles\": \"\",\n        \"heading\": \"Our story\",\n        \"image\": \"\",\n        \"imageAlt\": \"\",\n        \"imagePosition\": \"left\",\n        \"imageWidth\": \"50\",\n        \"mobile_styles\": \".demeurer-image-text-blk_imgt_qqqqqqqq {\\n  padding: 0;\\n}\",\n        \"padding_bottom\": 64,\n        \"padding_left\": 24,\n        \"padding_right\": 24,\n        \"padding_top\": 64,\n        \"scope_id\": \"demeurer-image-text-blk_imgt_qqqqqqqq\",\n        \"tablet_styles\": \"\",\n        \"visibility_styles\": \"\"\n      },\n      \"type\": \"demeurer-image-text\"\n    },\n    \"main-blk_spac\": {\n      \"settings\": {\n        \"desktop_styles\": \"\",\n        \"dividerColor\": \"#e5e7eb\",\n        \"dividerWidth\": \"thin\",\n        \"height\": 48,\n        \"mobile_styles\": \"\",\n        \"scope_id\": \"demeurer-spacer-blk_spac_ssssssss\",\n        \"showDivider\": false,\n        \"tablet_styles\": \"\",\n        \"visibility_styles\": \".demeurer-spacer-blk_spac_ssssssss { display: none !important; }\\n@media (min-width: 1280px) { .demeurer-spacer-blk_spac_ssssssss { display: revert !important; } }\"\n      },\n      \"type\": \"demeurer-spacer\"\n    }\n  }\n}\n",
