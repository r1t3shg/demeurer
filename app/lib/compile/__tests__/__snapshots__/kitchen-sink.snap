{
  "artifact": {
    "files": [
      {
        "content": "{%- liquid\n  assign scope = section.settings.scope_id | default: 'demeurer-cta-band'\n-%}\n{%- style -%}\n  {{ section.settings.mobile_styles }}\n  {%- if section.settings.tablet_styles != blank -%}\n    @media (min-width: 768px) { .{{ scope }} { {{ section.settings.tablet_styles }} } }\n  {%- endif -%}\n  {%- if section.settings.desktop_styles != blank -%}\n    @media (min-width: 1280px) { .{{ scope }} { {{ section.settings.desktop_styles }} } }\n  {%- endif -%}\n  {{ section.settings.visibility_styles }}\n{%- endstyle -%}\n\n{%- liquid\n  assign bg = section.settings.background\n  assign r = bg | color_extract: 'red' | default: 0\n  assign g = bg | color_extract: 'green' | default: 0\n  assign b = bg | color_extract: 'blue' | default: 0\n  assign luma = r | times: 0.2126\n  assign luma = g | times: 0.7152 | plus: luma\n  assign luma = b | times: 0.0722 | plus: luma\n  assign text_color = '#0a0a0a'\n  if luma < 140\n    assign text_color = '#ffffff'\n  endif\n-%}\n\n<section class=\"{{ scope }} demeurer-section demeurer-cta-band demeurer-cta-band--{{ section.settings.alignment }}\" style=\"color: {{ text_color }};\">\n  <div class=\"demeurer-cta-band__inner\" style=\"max-width: 720px; {% if section.settings.alignment == 'center' %}margin-inline: auto;{% endif %}\">\n    {%- if section.settings.heading != blank -%}\n      <h2 class=\"demeurer-cta-band__heading\" style=\"margin: 0; line-height: 1.2;\">{{ section.settings.heading | escape }}</h2>\n    {%- endif -%}\n    {%- if section.settings.subheading != blank -%}\n      <div class=\"demeurer-cta-band__subheading\" style=\"margin-top: 16px; line-height: 1.5; opacity: 0.85;\">{{ section.settings.subheading }}</div>\n    {%- endif -%}\n    {%- if section.settings.ctaLabel != blank or section.settings.secondaryCtaLabel != blank -%}\n      <div class=\"demeurer-cta-band__buttons\" style=\"display: flex; flex-wrap: wrap; gap: 12px; margin-top: 24px;{% if section.settings.alignment == 'center' %} justify-content: center;{% endif %}\">\n        {%- if section.settings.ctaLabel != blank -%}\n          <a class=\"demeurer-cta-band__cta\" href=\"{{ section.settings.ctaUrl | default: '#' }}\" style=\"display: inline-block; padding: 12px 24px; background: var(--demeurer-accent, #1a73e8); color: #fff; border-radius: 4px; text-decoration: none; font-weight: 600;\">{{ section.settings.ctaLabel | escape }}</a>\n        {%- endif -%}\n        {%- if section.settings.secondaryCtaLabel != blank -%}\n          <a class=\"demeurer-cta-band__cta-secondary\" href=\"{{ section.settings.secondaryCtaUrl | default: '#' }}\" style=\"display: inline-block; padding: 12px 24px; background: transparent; color: {{ text_color }}; border: 1px solid {{ text_color }}; border-radius: 4px; text-decoration: none; font-weight: 600;\">{{ section.settings.secondaryCtaLabel | escape }}</a>\n        {%- endif -%}\n      </div>\n    {%- endif -%}\n  </div>\n</section>\n\n{% schema %}\n{\n  \"class\": \"demeurer-section demeurer-cta-band\",\n  \"name\": \"Demeurer CTA band\",\n  \"presets\": [\n    {\n      \"name\": \"Demeurer CTA band\"\n    }\n  ],\n  \"settings\": [\n    {\n      \"id\": \"heading\",\n      \"label\": \"Heading\",\n      \"type\": \"textarea\"\n    },\n    {\n      \"id\": \"subheading\",\n      \"label\": \"Subheading\",\n      \"type\": \"richtext\"\n    },\n    {\n      \"id\": \"ctaLabel\",\n      \"label\": \"Primary CTA label\",\n      \"type\": \"textarea\"\n    },\n    {\n      \"id\": \"ctaUrl\",\n      \"label\": \"Primary CTA link\",\n      \"type\": \"url\"\n    },\n    {\n      \"id\": \"secondaryCtaLabel\",\n      \"label\": \"Secondary CTA label\",\n      \"type\": \"textarea\"\n    },\n    {\n      \"id\": \"secondaryCtaUrl\",\n      \"label\": \"Secondary CTA link\",\n      \"type\": \"url\"\n    },\n    {\n      \"id\": \"background\",\n      \"label\": \"Background color\",\n      \"type\": \"color\"\n    },\n    {\n      \"default\": \"center\",\n      \"id\": \"alignment\",\n      \"label\": \"Text alignment\",\n      \"options\": [\n        {\n          \"label\": \"Left\",\n          \"value\": \"left\"\n        },\n        {\n          \"label\": \"Center\",\n          \"value\": \"center\"\n        }\n      ],\n      \"type\": \"select\"\n    },\n    {\n      \"id\": \"padding_top\",\n      \"label\": \"Section padding (top)\",\n      \"type\": \"number\"\n    },\n    {\n      \"id\": \"padding_right\",\n      \"label\": \"Section padding (right)\",\n      \"type\": \"number\"\n    },\n    {\n      \"id\": \"padding_bottom\",\n      \"label\": \"Section padding (bottom)\",\n      \"type\": \"number\"\n    },\n    {\n      \"id\": \"padding_left\",\n      \"label\": \"Section padding (left)\",\n      \"type\": \"number\"\n    },\n    {\n      \"id\": \"scope_id\",\n      \"info\": \"\",\n      \"label\": \"Scope id\",\n      \"type\": \"text\"\n    },\n    {\n      \"id\": \"mobile_styles\",\n      \"info\": \"\",\n      \"label\": \"Mobile styles\",\n      \"type\": \"textarea\"\n    },\n    {\n      \"id\": \"tablet_styles\",\n      \"info\": \"\",\n      \"label\": \"Tablet styles\",\n      \"type\": \"textarea\"\n    },\n    {\n      \"id\": \"desktop_styles\",\n      \"info\": \"\",\n      \"label\": \"Desktop styles\",\n      \"type\": \"textarea\"\n    },\n    {\n      \"id\": \"visibility_styles\",\n      \"info\": \"\",\n      \"label\": \"Visibility styles\",\n      \"type\": \"textarea\"\n    }\n  ],\n  \"tag\": \"section\"\n}\n{% endschema %}\n",
        "contentHash": "5719929a8b456811e21ba911d75b522f3dac2a5ba873ef15e62b754071aaa9b5",
        "path": "sections/demeurer-cta-band.liquid",
        "purpose": "section",
        "sectionType": "cta-band"
      },
      {
        "content": "{%- liquid\n  assign scope = section.settings.scope_id | default: 'demeurer-faq'\n-%}\n{%- style -%}\n  {{ section.settings.mobile_styles }}\n  {%- if section.settings.tablet_styles != blank -%}\n    @media (min-width: 768px) { .{{ scope }} { {{ section.settings.tablet_styles }} } }\n  {%- endif -%}\n  {%- if section.settings.desktop_styles != blank -%}\n    @media (min-width: 1280px) { .{{ scope }} { {{ section.settings.desktop_styles }} } }\n  {%- endif -%}\n  {{ section.settings.visibility_styles }}\n{%- endstyle -%}\n\n<section class=\"{{ scope }} demeurer-section demeurer-faq\">\n  <div class=\"demeurer-faq__inner\" style=\"max-width: 720px; margin-inline: auto;\">\n    {%- if section.settings.heading != blank -%}\n      <h2 class=\"demeurer-faq__heading\" style=\"margin: 0 0 24px;\">{{ section.settings.heading | escape }}</h2>\n    {%- endif -%}\n    <div class=\"demeurer-faq__list\" style=\"display: flex; flex-direction: column; gap: 12px;\">\n      {%- for block in section.blocks -%}\n        <details class=\"demeurer-faq__item\" {{ block.shopify_attributes }} style=\"border: 1px solid #e5e7eb; border-radius: 6px; padding: 16px;\">\n          <summary class=\"demeurer-faq__question\" style=\"cursor: pointer; font-weight: 600; list-style: none;\">{{ block.settings.question | escape }}</summary>\n          {%- if block.settings.answer != blank -%}\n            <div class=\"demeurer-faq__answer\" style=\"margin-top: 12px; line-height: 1.5;\">{{ block.settings.answer }}</div>\n          {%- endif -%}\n        </details>\n      {%- endfor -%}\n    </div>\n  </div>\n</section>\n\n{% schema %}\n{\n  \"blocks\": [\n    {\n      \"limit\": 20,\n      \"name\": \"Questions\",\n      \"settings\": [\n        {\n          \"id\": \"question\",\n          \"label\": \"Question\",\n          \"type\": \"textarea\"\n        },\n        {\n          \"id\": \"answer\",\n          \"label\": \"Answer\",\n          \"type\": \"richtext\"\n        }\n      ],\n      \"type\": \"questions\"\n    }\n  ],\n  \"class\": \"demeurer-section demeurer-faq\",\n  \"name\": \"Demeurer FAQ\",\n  \"presets\": [\n    {\n      \"name\": \"Demeurer FAQ\"\n    }\n  ],\n  \"settings\": [\n    {\n      \"id\": \"heading\",\n      \"label\": \"Heading\",\n      \"type\": \"textarea\"\n    },\n    {\n      \"default\": \"left\",\n      \"id\": \"alignment\",\n      \"label\": \"Heading alignment\",\n      \"options\": [\n        {\n          \"label\": \"Left\",\n          \"value\": \"left\"\n        },\n        {\n          \"label\": \"Center\",\n          \"value\": \"center\"\n        }\n      ],\n      \"type\": \"select\"\n    },\n    {\n      \"id\": \"padding_top\",\n      \"label\": \"Section padding (top)\",\n      \"type\": \"number\"\n    },\n    {\n      \"id\": \"padding_right\",\n      \"label\": \"Section padding (right)\",\n      \"type\": \"number\"\n    },\n    {\n      \"id\": \"padding_bottom\",\n      \"label\": \"Section padding (bottom)\",\n      \"type\": \"number\"\n    },\n    {\n      \"id\": \"padding_left\",\n      \"label\": \"Section padding (left)\",\n      \"type\": \"number\"\n    },\n    {\n      \"id\": \"scope_id\",\n      \"info\": \"\",\n      \"label\": \"Scope id\",\n      \"type\": \"text\"\n    },\n    {\n      \"id\": \"mobile_styles\",\n      \"info\": \"\",\n      \"label\": \"Mobile styles\",\n      \"type\": \"textarea\"\n    },\n    {\n      \"id\": \"tablet_styles\",\n      \"info\": \"\",\n      \"label\": \"Tablet styles\",\n      \"type\": \"textarea\"\n    },\n    {\n      \"id\": \"desktop_styles\",\n      \"info\": \"\",\n      \"label\": \"Desktop styles\",\n      \"type\": \"textarea\"\n    },\n    {\n      \"id\": \"visibility_styles\",\n      \"info\": \"\",\n      \"label\": \"Visibility styles\",\n      \"type\": \"textarea\"\n    }\n  ],\n  \"tag\": \"section\"\n}\n{% endschema %}\n",
        "contentHash": "6c2a6a7c25b58f35037dd5cb2eb5592449b1b24ff63779bd018cc6e8cbbfdab5",
        "path": "sections/demeurer-faq.liquid",
        "purpose": "section",
        "sectionType": "faq"
      },
      {
        "content": "{%- liquid\n  assign scope = section.settings.scope_id | default: 'demeurer-feature-list'\n-%}\n{%- style -%}\n  {{ section.settings.mobile_styles }}\n  {%- if section.settings.tablet_styles != blank -%}\n    @media (min-width: 768px) { .{{ scope }} { {{ section.settings.tablet_styles }} } }\n  {%- endif -%}\n  {%- if section.settings.desktop_styles != blank -%}\n    @media (min-width: 1280px) { .{{ scope }} { {{ section.settings.desktop_styles }} } }\n  {%- endif -%}\n  {{ section.settings.visibility_styles }}\n{%- endstyle -%}\n\n{%- liquid\n  case section.settings.layout\n    when 'grid-2'\n      assign cols = 2\n    when 'grid-4'\n      assign cols = 4\n    when 'list'\n      assign cols = 1\n    else\n      assign cols = 3\n  endcase\n-%}\n\n<section class=\"{{ scope }} demeurer-section demeurer-feature-list demeurer-feature-list--{{ section.settings.alignment }}\">\n  <div class=\"demeurer-feature-list__inner\" style=\"max-width: 1200px; margin-inline: auto;\">\n    {%- if section.settings.heading != blank -%}\n      <h2 class=\"demeurer-feature-list__heading\">{{ section.settings.heading | escape }}</h2>\n    {%- endif -%}\n    {%- if section.settings.subheading != blank -%}\n      <div class=\"demeurer-feature-list__subheading\">{{ section.settings.subheading }}</div>\n    {%- endif -%}\n    <div class=\"demeurer-feature-list__grid\" style=\"display: grid; grid-template-columns: repeat({{ cols }}, minmax(0, 1fr)); gap: 32px; margin-top: 32px;\">\n      {%- for block in section.blocks -%}\n        <div class=\"demeurer-feature-list__item\" {{ block.shopify_attributes }} style=\"display: flex; flex-direction: column; gap: 12px;\">\n          <svg width=\"32\" height=\"32\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" aria-hidden=\"true\">\n{%- case block.settings.icon -%}\n        {%- when 'Sparkles' -%}\n          <path d=\"M9.937 15.5A2 2 0 0 0 8.5 14.063l-6.135-1.582a.5.5 0 0 1 0-.962L8.5 9.936A2 2 0 0 0 9.937 8.5l1.582-6.135a.5.5 0 0 1 .963 0L14.063 8.5A2 2 0 0 0 15.5 9.937l6.135 1.581a.5.5 0 0 1 0 .964L15.5 14.063a2 2 0 0 0-1.437 1.437l-1.582 6.135a.5.5 0 0 1-.963 0z\"/><path d=\"M20 3v4\"/><path d=\"M22 5h-4\"/><path d=\"M4 17v2\"/><path d=\"M5 18H3\"/>\n        {%- when 'Zap' -%}\n          <path d=\"M4 14a1 1 0 0 1-.78-1.63l9.9-10.2a.5.5 0 0 1 .86.46l-1.92 6.02A1 1 0 0 0 13 10h7a1 1 0 0 1 .78 1.63l-9.9 10.2a.5.5 0 0 1-.86-.46l1.92-6.02A1 1 0 0 0 11 14z\"/>\n        {%- when 'Shield' -%}\n          <path d=\"M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z\"/>\n        {%- when 'Heart' -%}\n          <path d=\"M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z\"/>\n        {%- when 'Star' -%}\n          <path d=\"M11.525 2.295a.53.53 0 0 1 .95 0l2.31 4.679a2.123 2.123 0 0 0 1.595 1.16l5.166.756a.53.53 0 0 1 .294.904l-3.736 3.638a2.123 2.123 0 0 0-.611 1.878l.882 5.14a.53.53 0 0 1-.771.56l-4.618-2.428a2.122 2.122 0 0 0-1.973 0L6.396 21.01a.53.53 0 0 1-.77-.56l.881-5.139a2.122 2.122 0 0 0-.611-1.879L2.16 9.795a.53.53 0 0 1 .294-.906l5.165-.755a2.122 2.122 0 0 0 1.597-1.16z\"/>\n        {%- when 'Award' -%}\n          <path d=\"m15.477 12.89 1.515 8.526a.5.5 0 0 1-.81.47l-3.58-2.687a1 1 0 0 0-1.197 0l-3.586 2.686a.5.5 0 0 1-.81-.469l1.514-8.526\"/><circle cx=\"12\" cy=\"8\" r=\"6\"/>\n        {%- when 'Rocket' -%}\n          <path d=\"M4.5 16.5c-1.5 1.26-2 5-2 5s3.74-.5 5-2c.71-.84.7-2.13-.09-2.91a2.18 2.18 0 0 0-2.91-.09z\"/><path d=\"m12 15-3-3a22 22 0 0 1 2-3.95A12.88 12.88 0 0 1 22 2c0 2.72-.78 7.5-6 11a22.35 22.35 0 0 1-4 2z\"/><path d=\"M9 12H4s.55-3.03 2-4c1.62-1.08 5 0 5 0\"/><path d=\"M12 15v5s3.03-.55 4-2c1.08-1.62 0-5 0-5\"/>\n        {%- when 'Globe' -%}\n          <circle cx=\"12\" cy=\"12\" r=\"10\"/><path d=\"M12 2a14.5 14.5 0 0 0 0 20 14.5 14.5 0 0 0 0-20\"/><path d=\"M2 12h20\"/>\n        {%- when 'Check' -%}\n          <path d=\"M20 6 9 17l-5-5\"/>\n        {%- when 'ThumbsUp' -%}\n          <path d=\"M7 10v12\"/><path d=\"M15 5.88 14 10h5.83a2 2 0 0 1 1.92 2.56l-2.33 8A2 2 0 0 1 17.5 22H7l-1-12 1.94-6.59A1.93 1.93 0 0 1 9.94 2h.06a2 2 0 0 1 2 2v.88a4 4 0 0 1-.06 1z\"/>\n        {%- else -%}\n          <path d=\"M9.937 15.5A2 2 0 0 0 8.5 14.063l-6.135-1.582a.5.5 0 0 1 0-.962L8.5 9.936A2 2 0 0 0 9.937 8.5l1.582-6.135a.5.5 0 0 1 .963 0L14.063 8.5A2 2 0 0 0 15.5 9.937l6.135 1.581a.5.5 0 0 1 0 .964L15.5 14.063a2 2 0 0 0-1.437 1.437l-1.582 6.135a.5.5 0 0 1-.963 0z\"/><path d=\"M20 3v4\"/><path d=\"M22 5h-4\"/><path d=\"M4 17v2\"/><path d=\"M5 18H3\"/>\n        {%- endcase -%}\n          </svg>\n          {%- if block.settings.title != blank -%}\n            <h3 class=\"demeurer-feature-list__title\" style=\"margin: 0; font-weight: 600;\">{{ block.settings.title | escape }}</h3>\n          {%- endif -%}\n          {%- if block.settings.description != blank -%}\n            <div class=\"demeurer-feature-list__desc\">{{ block.settings.description }}</div>\n          {%- endif -%}\n        </div>\n      {%- endfor -%}\n    </div>\n  </div>\n</section>\n\n{% schema %}\n{\n  \"blocks\": [\n    {\n      \"limit\": 12,\n      \"name\": \"Features\",\n      \"settings\": [\n        {\n          \"default\": \"Sparkles\",\n          \"id\": \"icon\",\n          \"label\": \"Icon\",\n          \"options\": [\n            {\n              \"label\": \"Sparkles\",\n              \"value\": \"Sparkles\"\n            },\n            {\n              \"label\": \"Zap\",\n              \"value\": \"Zap\"\n            },\n            {\n              \"label\": \"Shield\",\n              \"value\": \"Shield\"\n            },\n            {\n              \"label\": \"Heart\",\n              \"value\": \"Heart\"\n            },\n            {\n              \"label\": \"Star\",\n              \"value\": \"Star\"\n            },\n            {\n              \"label\": \"Award\",\n              \"value\": \"Award\"\n            },\n            {\n              \"label\": \"Rocket\",\n              \"value\": \"Rocket\"\n            },\n            {\n              \"label\": \"Globe\",\n              \"value\": \"Globe\"\n            },\n            {\n              \"label\": \"Check\",\n              \"value\": \"Check\"\n            },\n            {\n              \"label\": \"ThumbsUp\",\n              \"value\": \"ThumbsUp\"\n            }\n          ],\n          \"type\": \"select\"\n        },\n        {\n          \"id\": \"title\",\n          \"label\": \"Title\",\n          \"type\": \"text\"\n        },\n        {\n          \"id\": \"description\",\n          \"label\": \"Description\",\n          \"type\": \"richtext\"\n        }\n      ],\n      \"type\": \"features\"\n    }\n  ],\n  \"class\": \"demeurer-section demeurer-feature-list\",\n  \"name\": \"Demeurer Feature list\",\n  \"presets\": [\n    {\n      \"name\": \"Demeurer Feature list\"\n    }\n  ],\n  \"settings\": [\n    {\n      \"id\": \"heading\",\n      \"label\": \"Heading\",\n      \"type\": \"text\"\n    },\n    {\n      \"id\": \"subheading\",\n      \"label\": \"Subheading\",\n      \"type\": \"richtext\"\n    },\n    {\n      \"default\": \"grid-3\",\n      \"id\": \"layout\",\n      \"label\": \"Layout\",\n      \"options\": [\n        {\n          \"label\": \"3-column grid\",\n          \"value\": \"grid-3\"\n        },\n        {\n          \"label\": \"2-column grid\",\n          \"value\": \"grid-2\"\n        },\n        {\n          \"label\": \"4-column grid\",\n          \"value\": \"grid-4\"\n        },\n        {\n          \"label\": \"Vertical list\",\n          \"value\": \"list\"\n        }\n      ],\n      \"type\": \"select\"\n    },\n    {\n      \"default\": \"left\",\n      \"id\": \"alignment\",\n      \"label\": \"Text alignment\",\n      \"options\": [\n        {\n          \"label\": \"Left\",\n          \"value\": \"left\"\n        },\n        {\n          \"label\": \"Center\",\n          \"value\": \"center\"\n        }\n      ],\n      \"type\": \"select\"\n    },\n    {\n      \"id\": \"padding_top\",\n      \"label\": \"Section padding (top)\",\n      \"type\": \"number\"\n    },\n    {\n      \"id\": \"padding_right\",\n      \"label\": \"Section padding (right)\",\n      \"type\": \"number\"\n    },\n    {\n      \"id\": \"padding_bottom\",\n      \"label\": \"Section padding (bottom)\",\n      \"type\": \"number\"\n    },\n    {\n      \"id\": \"padding_left\",\n      \"label\": \"Section padding (left)\",\n      \"type\": \"number\"\n    },\n    {\n      \"id\": \"scope_id\",\n      \"info\": \"\",\n      \"label\": \"Scope id\",\n      \"type\": \"text\"\n    },\n    {\n      \"id\": \"mobile_styles\",\n      \"info\": \"\",\n      \"label\": \"Mobile styles\",\n      \"type\": \"textarea\"\n    },\n    {\n      \"id\": \"tablet_styles\",\n      \"info\": \"\",\n      \"label\": \"Tablet styles\",\n      \"type\": \"textarea\"\n    },\n    {\n      \"id\": \"desktop_styles\",\n      \"info\": \"\",\n      \"label\": \"Desktop styles\",\n      \"type\": \"textarea\"\n    },\n    {\n      \"id\": \"visibility_styles\",\n      \"info\": \"\",\n      \"label\": \"Visibility styles\",\n      \"type\": \"textarea\"\n    }\n  ],\n  \"tag\": \"section\"\n}\n{% endschema %}\n",
        "contentHash": "984f112b8cb23e1789cd1e5e64d16b144d6c58e09e001fa7fc741717ce279c6f",
        "path": "sections/demeurer-feature-list.liquid",
        "purpose": "section",
        "sectionType": "feature-list"
      },
      {
        "content": "{%- liquid\n  assign scope = section.settings.scope_id | default: 'demeurer-form'\n-%}\n{%- style -%}\n  {{ section.settings.mobile_styles }}\n  {%- if section.settings.tablet_styles != blank -%}\n    @media (min-width: 768px) { .{{ scope }} { {{ section.settings.tablet_styles }} } }\n  {%- endif -%}\n  {%- if section.settings.desktop_styles != blank -%}\n    @media (min-width: 1280px) { .{{ scope }} { {{ section.settings.desktop_styles }} } }\n  {%- endif -%}\n  {{ section.settings.visibility_styles }}\n{%- endstyle -%}\n\n{%- liquid\n  assign form_target = 'contact'\n  case section.settings.formType\n    when 'customer'\n      assign form_target = 'customer'\n    when 'newsletter'\n      assign form_target = 'customer'\n  endcase\n-%}\n\n<section class=\"{{ scope }} demeurer-section demeurer-form\">\n  <div class=\"demeurer-form__inner\" style=\"max-width: 600px; margin-inline: auto;\">\n    {%- if section.settings.heading != blank -%}\n      <h2 class=\"demeurer-form__heading\" style=\"margin: 0 0 12px;\">{{ section.settings.heading | escape }}</h2>\n    {%- endif -%}\n    {%- if section.settings.subheading != blank -%}\n      <div class=\"demeurer-form__subheading\" style=\"margin: 0 0 24px; opacity: 0.75;\">{{ section.settings.subheading }}</div>\n    {%- endif -%}\n\n    {%- form form_target -%}\n      {%- if form.posted_successfully? -%}\n        <div class=\"demeurer-form__success\" style=\"padding: 16px; background: #ecfdf5; color: #065f46; border-radius: 6px;\">{{ section.settings.successMessage }}</div>\n      {%- else -%}\n        {%- if form.errors -%}\n          <div class=\"demeurer-form__errors\" style=\"padding: 16px; background: #fef2f2; color: #991b1b; border-radius: 6px; margin-bottom: 16px;\">{{ form.errors | default_errors }}</div>\n        {%- endif -%}\n        <div class=\"demeurer-form__fields\" style=\"display: flex; flex-direction: column; gap: 16px;\">\n          {%- for block in section.blocks -%}\n            {%- assign field_name = block.settings.name | default: 'field_' | append: forloop.index -%}\n            {%- assign field_label = block.settings.label | default: field_name -%}\n            <label class=\"demeurer-form__field\" {{ block.shopify_attributes }} style=\"display: flex; flex-direction: column; gap: 6px;\">\n              <span class=\"demeurer-form__label\" style=\"font-weight: 600; font-size: 0.9em;\">{{ field_label | escape }}{% if block.settings.required %} <span aria-hidden=\"true\">*</span>{% endif %}</span>\n              {%- if block.settings.kind == 'textarea' -%}\n                <textarea name=\"contact[{{ field_name }}]\" rows=\"4\" {% if block.settings.required %}required{% endif %} style=\"padding: 8px 10px; border: 1px solid #d1d5db; border-radius: 4px; font: inherit;\"></textarea>\n              {%- elsif block.settings.kind == 'select' -%}\n                <select name=\"contact[{{ field_name }}]\" {% if block.settings.required %}required{% endif %} style=\"padding: 8px 10px; border: 1px solid #d1d5db; border-radius: 4px; font: inherit;\">\n                  {%- assign opts = block.settings.options | split: ',' -%}\n                  {%- for o in opts -%}\n                    {%- assign trimmed = o | strip -%}\n                    {%- if trimmed != blank -%}\n                      <option value=\"{{ trimmed }}\">{{ trimmed }}</option>\n                    {%- endif -%}\n                  {%- endfor -%}\n                </select>\n              {%- else -%}\n                <input type=\"{{ block.settings.kind | default: 'text' }}\" name=\"contact[{{ field_name }}]\" {% if block.settings.required %}required{% endif %} style=\"padding: 8px 10px; border: 1px solid #d1d5db; border-radius: 4px; font: inherit;\" />\n              {%- endif -%}\n            </label>\n          {%- endfor -%}\n        </div>\n        <button type=\"submit\" class=\"demeurer-form__submit\" style=\"margin-top: 24px; padding: 12px 24px; background: var(--demeurer-accent, #1a73e8); color: #fff; border: 0; border-radius: 4px; font-weight: 600; cursor: pointer;\">{{ section.settings.submitLabel | default: 'Submit' | escape }}</button>\n      {%- endif -%}\n    {%- endform -%}\n  </div>\n</section>\n\n{% schema %}\n{\n  \"blocks\": [\n    {\n      \"limit\": 8,\n      \"name\": \"Fields\",\n      \"settings\": [\n        {\n          \"id\": \"name\",\n          \"label\": \"Field name (no spaces)\",\n          \"type\": \"text\"\n        },\n        {\n          \"id\": \"label\",\n          \"label\": \"Label\",\n          \"type\": \"textarea\"\n        },\n        {\n          \"default\": \"text\",\n          \"id\": \"kind\",\n          \"label\": \"Type\",\n          \"options\": [\n            {\n              \"label\": \"Text\",\n              \"value\": \"text\"\n            },\n            {\n              \"label\": \"Email\",\n              \"value\": \"email\"\n            },\n            {\n              \"label\": \"Telephone\",\n              \"value\": \"tel\"\n            },\n            {\n              \"label\": \"Long text\",\n              \"value\": \"textarea\"\n            },\n            {\n              \"label\": \"Dropdown\",\n              \"value\": \"select\"\n            }\n          ],\n          \"type\": \"select\"\n        },\n        {\n          \"id\": \"required\",\n          \"label\": \"Required\",\n          \"type\": \"checkbox\"\n        },\n        {\n          \"id\": \"options\",\n          \"label\": \"Options (comma-separated, dropdown only)\",\n          \"type\": \"textarea\"\n        }\n      ],\n      \"type\": \"fields\"\n    }\n  ],\n  \"class\": \"demeurer-section demeurer-form\",\n  \"name\": \"Demeurer Form\",\n  \"presets\": [\n    {\n      \"name\": \"Demeurer Form\"\n    }\n  ],\n  \"settings\": [\n    {\n      \"id\": \"heading\",\n      \"label\": \"Heading\",\n      \"type\": \"textarea\"\n    },\n    {\n      \"id\": \"subheading\",\n      \"label\": \"Subheading\",\n      \"type\": \"richtext\"\n    },\n    {\n      \"default\": \"contact\",\n      \"id\": \"formType\",\n      \"label\": \"Form type\",\n      \"options\": [\n        {\n          \"label\": \"Contact\",\n          \"value\": \"contact\"\n        },\n        {\n          \"label\": \"Customer (account)\",\n          \"value\": \"customer\"\n        },\n        {\n          \"label\": \"Newsletter signup\",\n          \"value\": \"newsletter\"\n        }\n      ],\n      \"type\": \"select\"\n    },\n    {\n      \"id\": \"submitLabel\",\n      \"label\": \"Submit button label\",\n      \"type\": \"textarea\"\n    },\n    {\n      \"id\": \"successMessage\",\n      \"label\": \"Success message\",\n      \"type\": \"richtext\"\n    },\n    {\n      \"id\": \"padding_top\",\n      \"label\": \"Section padding (top)\",\n      \"type\": \"number\"\n    },\n    {\n      \"id\": \"padding_right\",\n      \"label\": \"Section padding (right)\",\n      \"type\": \"number\"\n    },\n    {\n      \"id\": \"padding_bottom\",\n      \"label\": \"Section padding (bottom)\",\n      \"type\": \"number\"\n    },\n    {\n      \"id\": \"padding_left\",\n      \"label\": \"Section padding (left)\",\n      \"type\": \"number\"\n    },\n    {\n      \"id\": \"scope_id\",\n      \"info\": \"\",\n      \"label\": \"Scope id\",\n      \"type\": \"text\"\n    },\n    {\n      \"id\": \"mobile_styles\",\n      \"info\": \"\",\n      \"label\": \"Mobile styles\",\n      \"type\": \"textarea\"\n    },\n    {\n      \"id\": \"tablet_styles\",\n      \"info\": \"\",\n      \"label\": \"Tablet styles\",\n      \"type\": \"textarea\"\n    },\n    {\n      \"id\": \"desktop_styles\",\n      \"info\": \"\",\n      \"label\": \"Desktop styles\",\n      \"type\": \"textarea\"\n    },\n    {\n      \"id\": \"visibility_styles\",\n      \"info\": \"\",\n      \"label\": \"Visibility styles\",\n      \"type\": \"textarea\"\n    }\n  ],\n  \"tag\": \"section\"\n}\n{% endschema %}\n",
        "contentHash": "49915578167040728f28c2eefe3e4c7fc30b8ae71d6318f0177727fad8103689",
        "path": "sections/demeurer-form.liquid",
        "purpose": "section",
        "sectionType": "form"
      },
      {
        "content": "{%- liquid\n  assign scope = section.settings.scope_id | default: 'demeurer-hero'\n-%}\n{%- style -%}\n  {{ section.settings.mobile_styles }}\n  {%- if section.settings.tablet_styles != blank -%}\n    @media (min-width: 768px) { .{{ scope }} { {{ section.settings.tablet_styles }} } }\n  {%- endif -%}\n  {%- if section.settings.desktop_styles != blank -%}\n    @media (min-width: 1280px) { .{{ scope }} { {{ section.settings.desktop_styles }} } }\n  {%- endif -%}\n  {{ section.settings.visibility_styles }}\n{%- endstyle -%}\n\n{%- if section.settings.bound_variant_ids != blank -%}\n  {%- assign current_variant_id = product.selected_or_first_available_variant.id | append: '' -%}\n  {%- assign bound_ids = section.settings.bound_variant_ids | split: ',' -%}\n  {%- assign should_render = false -%}\n  {%- for vid in bound_ids -%}\n    {%- assign normalized = vid | strip -%}\n    {%- if normalized == current_variant_id -%}\n      {%- assign should_render = true -%}\n    {%- endif -%}\n  {%- endfor -%}\n  {%- if should_render -%}\n<section class=\"{{ scope }} demeurer-section demeurer-hero demeurer-hero--{{ section.settings.alignment }}\" style=\"position: relative; overflow: hidden; min-height: 240px;\">\n  {%- if section.settings.backgroundImage != blank -%}\n    <div class=\"demeurer-hero__bg\" style=\"position: absolute; inset: 0; z-index: 0; background-image: url('{{ section.settings.backgroundImage | image_url: width: 2400 }}'); background-size: cover; background-position: center;\" role=\"presentation\"></div>\n    <div class=\"demeurer-hero__overlay\" style=\"position: absolute; inset: 0; z-index: 1; background-color: {{ section.settings.overlayColor }}; pointer-events: none;\" aria-hidden=\"true\"></div>\n  {%- endif -%}\n\n  <div class=\"demeurer-hero__content\" style=\"position: relative; z-index: 2; max-width: 720px; margin-inline: auto;\">\n    {%- if section.settings.heading != blank -%}\n      <h1 class=\"demeurer-hero__heading\">{{ section.settings.heading | escape }}</h1>\n    {%- endif -%}\n    {%- if section.settings.subheading != blank -%}\n      <div class=\"demeurer-hero__subheading\">{{ section.settings.subheading }}</div>\n    {%- endif -%}\n    {%- if section.settings.ctaLabel != blank -%}\n      <a class=\"demeurer-hero__cta\" href=\"{{ section.settings.ctaUrl | default: '#' }}\">{{ section.settings.ctaLabel | escape }}</a>\n    {%- endif -%}\n  </div>\n</section>\n  {%- endif -%}\n{%- else -%}\n<section class=\"{{ scope }} demeurer-section demeurer-hero demeurer-hero--{{ section.settings.alignment }}\" style=\"position: relative; overflow: hidden; min-height: 240px;\">\n  {%- if section.settings.backgroundImage != blank -%}\n    <div class=\"demeurer-hero__bg\" style=\"position: absolute; inset: 0; z-index: 0; background-image: url('{{ section.settings.backgroundImage | image_url: width: 2400 }}'); background-size: cover; background-position: center;\" role=\"presentation\"></div>\n    <div class=\"demeurer-hero__overlay\" style=\"position: absolute; inset: 0; z-index: 1; background-color: {{ section.settings.overlayColor }}; pointer-events: none;\" aria-hidden=\"true\"></div>\n  {%- endif -%}\n\n  <div class=\"demeurer-hero__content\" style=\"position: relative; z-index: 2; max-width: 720px; margin-inline: auto;\">\n    {%- if section.settings.heading != blank -%}\n      <h1 class=\"demeurer-hero__heading\">{{ section.settings.heading | escape }}</h1>\n    {%- endif -%}\n    {%- if section.settings.subheading != blank -%}\n      <div class=\"demeurer-hero__subheading\">{{ section.settings.subheading }}</div>\n    {%- endif -%}\n    {%- if section.settings.ctaLabel != blank -%}\n      <a class=\"demeurer-hero__cta\" href=\"{{ section.settings.ctaUrl | default: '#' }}\">{{ section.settings.ctaLabel | escape }}</a>\n    {%- endif -%}\n  </div>\n</section>\n{%- endif -%}\n\n{% schema %}\n{\n  \"class\": \"demeurer-section demeurer-hero\",\n  \"name\": \"Demeurer Hero\",\n  \"presets\": [\n    {\n      \"name\": \"Demeurer Hero\"\n    }\n  ],\n  \"settings\": [\n    {\n      \"id\": \"heading\",\n      \"label\": \"Heading\",\n      \"type\": \"textarea\"\n    },\n    {\n      \"id\": \"subheading\",\n      \"label\": \"Subheading\",\n      \"type\": \"richtext\"\n    },\n    {\n      \"id\": \"backgroundImage\",\n      \"label\": \"Background image\",\n      \"type\": \"image_picker\"\n    },\n    {\n      \"default\": \"center\",\n      \"id\": \"alignment\",\n      \"label\": \"Text alignment\",\n      \"options\": [\n        {\n          \"label\": \"Left\",\n          \"value\": \"left\"\n        },\n        {\n          \"label\": \"Center\",\n          \"value\": \"center\"\n        }\n      ],\n      \"type\": \"select\"\n    },\n    {\n      \"id\": \"ctaUrl\",\n      \"label\": \"CTA link\",\n      \"type\": \"url\"\n    },\n    {\n      \"id\": \"ctaLabel\",\n      \"label\": \"CTA button text\",\n      \"type\": \"textarea\"\n    },\n    {\n      \"id\": \"overlayColor\",\n      \"label\": \"Image overlay\",\n      \"type\": \"color\"\n    },\n    {\n      \"id\": \"padding_top\",\n      \"label\": \"Section padding (top)\",\n      \"type\": \"number\"\n    },\n    {\n      \"id\": \"padding_right\",\n      \"label\": \"Section padding (right)\",\n      \"type\": \"number\"\n    },\n    {\n      \"id\": \"padding_bottom\",\n      \"label\": \"Section padding (bottom)\",\n      \"type\": \"number\"\n    },\n    {\n      \"id\": \"padding_left\",\n      \"label\": \"Section padding (left)\",\n      \"type\": \"number\"\n    },\n    {\n      \"id\": \"scope_id\",\n      \"info\": \"\",\n      \"label\": \"Scope id\",\n      \"type\": \"text\"\n    },\n    {\n      \"id\": \"mobile_styles\",\n      \"info\": \"\",\n      \"label\": \"Mobile styles\",\n      \"type\": \"textarea\"\n    },\n    {\n      \"id\": \"tablet_styles\",\n      \"info\": \"\",\n      \"label\": \"Tablet styles\",\n      \"type\": \"textarea\"\n    },\n    {\n      \"id\": \"desktop_styles\",\n      \"info\": \"\",\n      \"label\": \"Desktop styles\",\n      \"type\": \"textarea\"\n    },\n    {\n      \"id\": \"visibility_styles\",\n      \"info\": \"\",\n      \"label\": \"Visibility styles\",\n      \"type\": \"textarea\"\n    },\n    {\n      \"id\": \"bound_variant_ids\",\n      \"info\": \"\",\n      \"label\": \"Bound variant ids\",\n      \"type\": \"text\"\n    }\n  ],\n  \"tag\": \"section\"\n}\n{% endschema %}\n",
        "contentHash": "f1a009f58be7f4d8e6c27dd464b000ab0a1490917625130fa98ec47e47222979",
        "path": "sections/demeurer-hero.liquid",
        "purpose": "section",
        "sectionType": "hero"
      },
      {
        "content": "{%- liquid\n  assign scope = section.settings.scope_id | default: 'demeurer-html'\n-%}\n{%- style -%}\n  {{ section.settings.mobile_styles }}\n  {%- if section.settings.tablet_styles != blank -%}\n    @media (min-width: 768px) { .{{ scope }} { {{ section.settings.tablet_styles }} } }\n  {%- endif -%}\n  {%- if section.settings.desktop_styles != blank -%}\n    @media (min-width: 1280px) { .{{ scope }} { {{ section.settings.desktop_styles }} } }\n  {%- endif -%}\n  {{ section.settings.visibility_styles }}\n{%- endstyle -%}\n\n<section class=\"{{ scope }} demeurer-section demeurer-html\">\n  {{ section.settings.html }}\n</section>\n\n{% schema %}\n{\n  \"class\": \"demeurer-section demeurer-html\",\n  \"name\": \"Demeurer Custom HTML\",\n  \"presets\": [\n    {\n      \"name\": \"Demeurer Custom HTML\"\n    }\n  ],\n  \"settings\": [\n    {\n      \"id\": \"html\",\n      \"label\": \"Custom HTML\",\n      \"type\": \"richtext\"\n    },\n    {\n      \"id\": \"notes\",\n      \"label\": \"Notes (editor only — not rendered)\",\n      \"type\": \"textarea\"\n    },\n    {\n      \"id\": \"padding_top\",\n      \"label\": \"Section padding (top)\",\n      \"type\": \"number\"\n    },\n    {\n      \"id\": \"padding_right\",\n      \"label\": \"Section padding (right)\",\n      \"type\": \"number\"\n    },\n    {\n      \"id\": \"padding_bottom\",\n      \"label\": \"Section padding (bottom)\",\n      \"type\": \"number\"\n    },\n    {\n      \"id\": \"padding_left\",\n      \"label\": \"Section padding (left)\",\n      \"type\": \"number\"\n    },\n    {\n      \"id\": \"scope_id\",\n      \"info\": \"\",\n      \"label\": \"Scope id\",\n      \"type\": \"text\"\n    },\n    {\n      \"id\": \"mobile_styles\",\n      \"info\": \"\",\n      \"label\": \"Mobile styles\",\n      \"type\": \"textarea\"\n    },\n    {\n      \"id\": \"tablet_styles\",\n      \"info\": \"\",\n      \"label\": \"Tablet styles\",\n      \"type\": \"textarea\"\n    },\n    {\n      \"id\": \"desktop_styles\",\n      \"info\": \"\",\n      \"label\": \"Desktop styles\",\n      \"type\": \"textarea\"\n    },\n    {\n      \"id\": \"visibility_styles\",\n      \"info\": \"\",\n      \"label\": \"Visibility styles\",\n      \"type\": \"textarea\"\n    }\n  ],\n  \"tag\": \"section\"\n}\n{% endschema %}\n",
        "contentHash": "befd4586bca3543ccec134d4c4286c83227929af3bcfd934873e5c8b9f6a7fed",
        "path": "sections/demeurer-html.liquid",
        "purpose": "section",
        "sectionType": "html"
      },
      {
        "content": "{%- liquid\n  assign scope = section.settings.scope_id | default: 'demeurer-image-text'\n-%}\n{%- style -%}\n  {{ section.settings.mobile_styles }}\n  {%- if section.settings.tablet_styles != blank -%}\n    @media (min-width: 768px) { .{{ scope }} { {{ section.settings.tablet_styles }} } }\n  {%- endif -%}\n  {%- if section.settings.desktop_styles != blank -%}\n    @media (min-width: 1280px) { .{{ scope }} { {{ section.settings.desktop_styles }} } }\n  {%- endif -%}\n  {{ section.settings.visibility_styles }}\n{%- endstyle -%}\n\n{%- if section.settings.bound_variant_ids != blank -%}\n  {%- assign current_variant_id = product.selected_or_first_available_variant.id | append: '' -%}\n  {%- assign bound_ids = section.settings.bound_variant_ids | split: ',' -%}\n  {%- assign should_render = false -%}\n  {%- for vid in bound_ids -%}\n    {%- assign normalized = vid | strip -%}\n    {%- if normalized == current_variant_id -%}\n      {%- assign should_render = true -%}\n    {%- endif -%}\n  {%- endfor -%}\n  {%- if should_render -%}\n{%- liquid\n  assign image_pct = section.settings.imageWidth | plus: 0\n  assign text_pct = 100 | minus: image_pct\n  assign flex_dir = 'row'\n  if section.settings.imagePosition == 'right'\n    assign flex_dir = 'row-reverse'\n  endif\n-%}\n\n<section class=\"{{ scope }} demeurer-section demeurer-image-text\">\n  <div class=\"demeurer-image-text__inner\" style=\"max-width: 1200px; margin-inline: auto; display: flex; flex-direction: {{ flex_dir }}; flex-wrap: wrap; align-items: center; gap: 48px;\">\n    <div class=\"demeurer-image-text__image\" style=\"flex: 1 1 {{ image_pct }}%; min-width: 240px;\">\n      {%- if section.settings.image != blank -%}\n        {%- assign alt = section.settings.imageAlt | default: section.settings.image.alt | default: '' -%}\n        {{ section.settings.image | image_url: width: 1600 | image_tag:\n          loading: 'lazy',\n          widths: '400, 600, 800, 1200, 1600',\n          sizes: '(min-width: 768px) 50vw, 100vw',\n          alt: alt,\n          class: 'demeurer-image-text__img',\n          style: 'width: 100%; height: auto; border-radius: 8px; display: block;'\n        }}\n      {%- else -%}\n        <div style=\"aspect-ratio: 4 / 3; background: #e5e7eb; border-radius: 8px;\"></div>\n      {%- endif -%}\n    </div>\n    <div class=\"demeurer-image-text__text\" style=\"flex: 1 1 {{ text_pct }}%; min-width: 240px;\">\n      {%- if section.settings.heading != blank -%}\n        <h2 class=\"demeurer-image-text__heading\" style=\"margin: 0;\">{{ section.settings.heading | escape }}</h2>\n      {%- endif -%}\n      {%- if section.settings.body != blank -%}\n        <div class=\"demeurer-image-text__body\" style=\"margin-top: 16px; line-height: 1.6;\">{{ section.settings.body }}</div>\n      {%- endif -%}\n      {%- if section.settings.ctaLabel != blank -%}\n        <a class=\"demeurer-image-text__cta\" href=\"{{ section.settings.ctaUrl | default: '#' }}\" style=\"display: inline-block; margin-top: 24px; padding: 12px 24px; background: var(--demeurer-accent, #1a73e8); color: #fff; border-radius: 4px; text-decoration: none; font-weight: 600;\">{{ section.settings.ctaLabel | escape }}</a>\n      {%- endif -%}\n    </div>\n  </div>\n</section>\n  {%- endif -%}\n{%- else -%}\n{%- liquid\n  assign image_pct = section.settings.imageWidth | plus: 0\n  assign text_pct = 100 | minus: image_pct\n  assign flex_dir = 'row'\n  if section.settings.imagePosition == 'right'\n    assign flex_dir = 'row-reverse'\n  endif\n-%}\n\n<section class=\"{{ scope }} demeurer-section demeurer-image-text\">\n  <div class=\"demeurer-image-text__inner\" style=\"max-width: 1200px; margin-inline: auto; display: flex; flex-direction: {{ flex_dir }}; flex-wrap: wrap; align-items: center; gap: 48px;\">\n    <div class=\"demeurer-image-text__image\" style=\"flex: 1 1 {{ image_pct }}%; min-width: 240px;\">\n      {%- if section.settings.image != blank -%}\n        {%- assign alt = section.settings.imageAlt | default: section.settings.image.alt | default: '' -%}\n        {{ section.settings.image | image_url: width: 1600 | image_tag:\n          loading: 'lazy',\n          widths: '400, 600, 800, 1200, 1600',\n          sizes: '(min-width: 768px) 50vw, 100vw',\n          alt: alt,\n          class: 'demeurer-image-text__img',\n          style: 'width: 100%; height: auto; border-radius: 8px; display: block;'\n        }}\n      {%- else -%}\n        <div style=\"aspect-ratio: 4 / 3; background: #e5e7eb; border-radius: 8px;\"></div>\n      {%- endif -%}\n    </div>\n    <div class=\"demeurer-image-text__text\" style=\"flex: 1 1 {{ text_pct }}%; min-width: 240px;\">\n      {%- if section.settings.heading != blank -%}\n        <h2 class=\"demeurer-image-text__heading\" style=\"margin: 0;\">{{ section.settings.heading | escape }}</h2>\n      {%- endif -%}\n      {%- if section.settings.body != blank -%}\n        <div class=\"demeurer-image-text__body\" style=\"margin-top: 16px; line-height: 1.6;\">{{ section.settings.body }}</div>\n      {%- endif -%}\n      {%- if section.settings.ctaLabel != blank -%}\n        <a class=\"demeurer-image-text__cta\" href=\"{{ section.settings.ctaUrl | default: '#' }}\" style=\"display: inline-block; margin-top: 24px; padding: 12px 24px; background: var(--demeurer-accent, #1a73e8); color: #fff; border-radius: 4px; text-decoration: none; font-weight: 600;\">{{ section.settings.ctaLabel | escape }}</a>\n      {%- endif -%}\n    </div>\n  </div>\n</section>\n{%- endif -%}\n\n{% schema %}\n{\n  \"class\": \"demeurer-section demeurer-image-text\",\n  \"name\": \"Demeurer Image + text\",\n  \"presets\": [\n    {\n      \"name\": \"Demeurer Image + text\"\n    }\n  ],\n  \"settings\": [\n    {\n      \"id\": \"image\",\n      \"label\": \"Image\",\n      \"type\": \"image_picker\"\n    },\n    {\n      \"id\": \"imageAlt\",\n      \"label\": \"Image alt text\",\n      \"type\": \"textarea\"\n    },\n    {\n      \"default\": \"left\",\n      \"id\": \"imagePosition\",\n      \"label\": \"Image position\",\n      \"options\": [\n        {\n          \"label\": \"Left\",\n          \"value\": \"left\"\n        },\n        {\n          \"label\": \"Right\",\n          \"value\": \"right\"\n        }\n      ],\n      \"type\": \"select\"\n    },\n    {\n      \"default\": \"50\",\n      \"id\": \"imageWidth\",\n      \"label\": \"Image width\",\n      \"options\": [\n        {\n          \"label\": \"40%\",\n          \"value\": \"40\"\n        },\n        {\n          \"label\": \"50%\",\n          \"value\": \"50\"\n        },\n        {\n          \"label\": \"60%\",\n          \"value\": \"60\"\n        }\n      ],\n      \"type\": \"select\"\n    },\n    {\n      \"id\": \"heading\",\n      \"label\": \"Heading\",\n      \"type\": \"textarea\"\n    },\n    {\n      \"id\": \"body\",\n      \"label\": \"Body\",\n      \"type\": \"richtext\"\n    },\n    {\n      \"id\": \"ctaLabel\",\n      \"label\": \"CTA label\",\n      \"type\": \"textarea\"\n    },\n    {\n      \"id\": \"ctaUrl\",\n      \"label\": \"CTA link\",\n      \"type\": \"url\"\n    },\n    {\n      \"id\": \"padding_top\",\n      \"label\": \"Section padding (top)\",\n      \"type\": \"number\"\n    },\n    {\n      \"id\": \"padding_right\",\n      \"label\": \"Section padding (right)\",\n      \"type\": \"number\"\n    },\n    {\n      \"id\": \"padding_bottom\",\n      \"label\": \"Section padding (bottom)\",\n      \"type\": \"number\"\n    },\n    {\n      \"id\": \"padding_left\",\n      \"label\": \"Section padding (left)\",\n      \"type\": \"number\"\n    },\n    {\n      \"id\": \"scope_id\",\n      \"info\": \"\",\n      \"label\": \"Scope id\",\n      \"type\": \"text\"\n    },\n    {\n      \"id\": \"mobile_styles\",\n      \"info\": \"\",\n      \"label\": \"Mobile styles\",\n      \"type\": \"textarea\"\n    },\n    {\n      \"id\": \"tablet_styles\",\n      \"info\": \"\",\n      \"label\": \"Tablet styles\",\n      \"type\": \"textarea\"\n    },\n    {\n      \"id\": \"desktop_styles\",\n      \"info\": \"\",\n      \"label\": \"Desktop styles\",\n      \"type\": \"textarea\"\n    },\n    {\n      \"id\": \"visibility_styles\",\n      \"info\": \"\",\n      \"label\": \"Visibility styles\",\n      \"type\": \"textarea\"\n    },\n    {\n      \"id\": \"bound_variant_ids\",\n      \"info\": \"\",\n      \"label\": \"Bound variant ids\",\n      \"type\": \"text\"\n    }\n  ],\n  \"tag\": \"section\"\n}\n{% endschema %}\n",
        "contentHash": "cae8fff91955828de6db08fc3eaa99fa303bc1a911db0b07d7cba8f130e5ae85",
        "path": "sections/demeurer-image-text.liquid",
        "purpose": "section",
        "sectionType": "image-text"
      },
      {
        "content": "{%- liquid\n  assign scope = section.settings.scope_id | default: 'demeurer-logo-wall'\n-%}\n{%- style -%}\n  {{ section.settings.mobile_styles }}\n  {%- if section.settings.tablet_styles != blank -%}\n    @media (min-width: 768px) { .{{ scope }} { {{ section.settings.tablet_styles }} } }\n  {%- endif -%}\n  {%- if section.settings.desktop_styles != blank -%}\n    @media (min-width: 1280px) { .{{ scope }} { {{ section.settings.desktop_styles }} } }\n  {%- endif -%}\n  {{ section.settings.visibility_styles }}\n{%- endstyle -%}\n\n{%- liquid\n  case section.settings.logoSize\n    when 'small'\n      assign logo_h = 28\n    when 'large'\n      assign logo_h = 56\n    else\n      assign logo_h = 40\n  endcase\n-%}\n\n<section class=\"{{ scope }} demeurer-section demeurer-logo-wall\">\n  <div class=\"demeurer-logo-wall__inner\" style=\"max-width: 1200px; margin-inline: auto;\">\n    {%- if section.settings.heading != blank -%}\n      <h3 class=\"demeurer-logo-wall__heading\" style=\"margin: 0 0 24px; text-align: center; font-size: 14px; font-weight: 600; letter-spacing: 0.05em; text-transform: uppercase; opacity: 0.7;\">{{ section.settings.heading | escape }}</h3>\n    {%- endif -%}\n\n    {%- if section.settings.layout == 'marquee' -%}\n      <div class=\"demeurer-logo-wall__marquee\" style=\"overflow: hidden; mask-image: linear-gradient(to right, transparent, #000 12%, #000 88%, transparent);\">\n        <div class=\"demeurer-logo-wall__track\" style=\"display: flex; gap: 48px; animation: demeurer-logo-marquee 30s linear infinite; align-items: center; width: max-content;\">\n          {%- for block in section.blocks -%}\n            {%- if block.settings.image != blank -%}\n              {%- if block.settings.link != blank -%}\n                <a href=\"{{ block.settings.link }}\" {{ block.shopify_attributes }}>\n                  {{ block.settings.image | image_url: height: logo_h | image_tag:\n                    height: logo_h, alt: block.settings.alt, loading: 'lazy',\n                    style: 'height: 100%; width: auto; display: block;' }}\n                </a>\n              {%- else -%}\n                <span {{ block.shopify_attributes }}>\n                  {{ block.settings.image | image_url: height: logo_h | image_tag:\n                    height: logo_h, alt: block.settings.alt, loading: 'lazy',\n                    style: 'height: 100%; width: auto; display: block;' }}\n                </span>\n              {%- endif -%}\n            {%- endif -%}\n          {%- endfor -%}\n        </div>\n      </div>\n      <style>\n        @keyframes demeurer-logo-marquee {\n          from { transform: translateX(0); }\n          to { transform: translateX(-50%); }\n        }\n      </style>\n    {%- else -%}\n      <div class=\"demeurer-logo-wall__grid\" style=\"display: flex; flex-wrap: wrap; gap: 48px; align-items: center; justify-content: center;\">\n        {%- for block in section.blocks -%}\n          {%- if block.settings.image != blank -%}\n            {%- if block.settings.link != blank -%}\n              <a href=\"{{ block.settings.link }}\" {{ block.shopify_attributes }}>\n                {{ block.settings.image | image_url: height: logo_h | image_tag:\n                  height: logo_h, alt: block.settings.alt, loading: 'lazy',\n                  style: 'height: 100%; width: auto; display: block; opacity: 0.75;' }}\n              </a>\n            {%- else -%}\n              <span {{ block.shopify_attributes }}>\n                {{ block.settings.image | image_url: height: logo_h | image_tag:\n                  height: logo_h, alt: block.settings.alt, loading: 'lazy',\n                  style: 'height: 100%; width: auto; display: block; opacity: 0.75;' }}\n              </span>\n            {%- endif -%}\n          {%- endif -%}\n        {%- endfor -%}\n      </div>\n    {%- endif -%}\n  </div>\n</section>\n\n{% schema %}\n{\n  \"blocks\": [\n    {\n      \"limit\": 12,\n      \"name\": \"Logos\",\n      \"settings\": [\n        {\n          \"id\": \"image\",\n          \"label\": \"Logo image\",\n          \"type\": \"image_picker\"\n        },\n        {\n          \"id\": \"alt\",\n          \"label\": \"Alt text\",\n          \"type\": \"textarea\"\n        },\n        {\n          \"id\": \"link\",\n          \"label\": \"Link (optional)\",\n          \"type\": \"url\"\n        }\n      ],\n      \"type\": \"logos\"\n    }\n  ],\n  \"class\": \"demeurer-section demeurer-logo-wall\",\n  \"name\": \"Demeurer Logo wall\",\n  \"presets\": [\n    {\n      \"name\": \"Demeurer Logo wall\"\n    }\n  ],\n  \"settings\": [\n    {\n      \"id\": \"heading\",\n      \"label\": \"Heading\",\n      \"type\": \"textarea\"\n    },\n    {\n      \"default\": \"grid\",\n      \"id\": \"layout\",\n      \"label\": \"Layout\",\n      \"options\": [\n        {\n          \"label\": \"Grid\",\n          \"value\": \"grid\"\n        },\n        {\n          \"label\": \"Marquee\",\n          \"value\": \"marquee\"\n        }\n      ],\n      \"type\": \"select\"\n    },\n    {\n      \"default\": \"medium\",\n      \"id\": \"logoSize\",\n      \"label\": \"Logo size\",\n      \"options\": [\n        {\n          \"label\": \"Small\",\n          \"value\": \"small\"\n        },\n        {\n          \"label\": \"Medium\",\n          \"value\": \"medium\"\n        },\n        {\n          \"label\": \"Large\",\n          \"value\": \"large\"\n        }\n      ],\n      \"type\": \"select\"\n    },\n    {\n      \"id\": \"padding_top\",\n      \"label\": \"Section padding (top)\",\n      \"type\": \"number\"\n    },\n    {\n      \"id\": \"padding_right\",\n      \"label\": \"Section padding (right)\",\n      \"type\": \"number\"\n    },\n    {\n      \"id\": \"padding_bottom\",\n      \"label\": \"Section padding (bottom)\",\n      \"type\": \"number\"\n    },\n    {\n      \"id\": \"padding_left\",\n      \"label\": \"Section padding (left)\",\n      \"type\": \"number\"\n    },\n    {\n      \"id\": \"scope_id\",\n      \"info\": \"\",\n      \"label\": \"Scope id\",\n      \"type\": \"text\"\n    },\n    {\n      \"id\": \"mobile_styles\",\n      \"info\": \"\",\n      \"label\": \"Mobile styles\",\n      \"type\": \"textarea\"\n    },\n    {\n      \"id\": \"tablet_styles\",\n      \"info\": \"\",\n      \"label\": \"Tablet styles\",\n      \"type\": \"textarea\"\n    },\n    {\n      \"id\": \"desktop_styles\",\n      \"info\": \"\",\n      \"label\": \"Desktop styles\",\n      \"type\": \"textarea\"\n    },\n    {\n      \"id\": \"visibility_styles\",\n      \"info\": \"\",\n      \"label\": \"Visibility styles\",\n      \"type\": \"textarea\"\n    }\n  ],\n  \"tag\": \"section\"\n}\n{% endschema %}\n",
        "contentHash": "07ccabdc02f7407a6e323fceff50231d2da7db66c786507f51745958db24d79e",
        "path": "sections/demeurer-logo-wall.liquid",
        "purpose": "section",
        "sectionType": "logo-wall"
      },
      {
        "content": "{%- liquid\n  assign scope = section.settings.scope_id | default: 'demeurer-pricing'\n-%}\n{%- style -%}\n  {{ section.settings.mobile_styles }}\n  {%- if section.settings.tablet_styles != blank -%}\n    @media (min-width: 768px) { .{{ scope }} { {{ section.settings.tablet_styles }} } }\n  {%- endif -%}\n  {%- if section.settings.desktop_styles != blank -%}\n    @media (min-width: 1280px) { .{{ scope }} { {{ section.settings.desktop_styles }} } }\n  {%- endif -%}\n  {{ section.settings.visibility_styles }}\n{%- endstyle -%}\n\n<section class=\"{{ scope }} demeurer-section demeurer-pricing demeurer-pricing--monthly\">\n  <div class=\"demeurer-pricing__inner\" style=\"max-width: 1200px; margin-inline: auto;\">\n    {%- if section.settings.heading != blank -%}\n      <h2 class=\"demeurer-pricing__heading\" style=\"text-align: center; margin: 0;\">{{ section.settings.heading | escape }}</h2>\n    {%- endif -%}\n    {%- if section.settings.subheading != blank -%}\n      <div class=\"demeurer-pricing__subheading\" style=\"text-align: center; margin: 12px auto 0; max-width: 600px;\">{{ section.settings.subheading }}</div>\n    {%- endif -%}\n\n    {%- if section.settings.billingToggle -%}\n      <div class=\"demeurer-pricing__toggle\" style=\"display: flex; justify-content: center; gap: 8px; margin-top: 24px;\">\n        <button type=\"button\" class=\"demeurer-pricing__toggle-btn\" data-billing=\"monthly\" aria-pressed=\"true\" style=\"padding: 8px 16px; border: 1px solid #d1d5db; background: #f9fafb; border-radius: 4px; cursor: pointer;\">Monthly</button>\n        <button type=\"button\" class=\"demeurer-pricing__toggle-btn\" data-billing=\"yearly\" aria-pressed=\"false\" style=\"padding: 8px 16px; border: 1px solid #d1d5db; background: transparent; border-radius: 4px; cursor: pointer;\">Yearly</button>\n      </div>\n    {%- endif -%}\n\n    <div class=\"demeurer-pricing__tiers\" style=\"display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); gap: 24px; margin-top: 32px;\">\n      {%- for block in section.blocks -%}\n        <article class=\"demeurer-pricing__tier{% if block.settings.highlighted %} demeurer-pricing__tier--highlighted{% endif %}\" {{ block.shopify_attributes }} style=\"padding: 24px; border: 1px solid {% if block.settings.highlighted %}var(--demeurer-accent, #1a73e8){% else %}#e5e7eb{% endif %}; border-radius: 8px; display: flex; flex-direction: column; gap: 16px;\">\n          {%- if block.settings.badge != blank -%}\n            <div class=\"demeurer-pricing__badge\" style=\"display: inline-block; padding: 4px 8px; background: var(--demeurer-accent, #1a73e8); color: #fff; border-radius: 12px; font-size: 0.75em; align-self: flex-start;\">{{ block.settings.badge | escape }}</div>\n          {%- endif -%}\n          {%- if block.settings.name != blank -%}\n            <h3 class=\"demeurer-pricing__name\" style=\"margin: 0; font-size: 1.25rem;\">{{ block.settings.name | escape }}</h3>\n          {%- endif -%}\n          {%- if block.settings.description != blank -%}\n            <p class=\"demeurer-pricing__description\" style=\"margin: 0; opacity: 0.75;\">{{ block.settings.description | escape }}</p>\n          {%- endif -%}\n          <div class=\"demeurer-pricing__price\" style=\"font-size: 2rem; font-weight: 700;\">\n            <span class=\"demeurer-pricing__price-monthly\">{{ block.settings.priceMonthly | escape }}</span>\n            <span class=\"demeurer-pricing__price-yearly\" style=\"display: none;\">{{ block.settings.priceYearly | escape }}</span>\n          </div>\n          {%- if block.settings.features != blank -%}\n            <ul class=\"demeurer-pricing__features\" style=\"list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 8px;\">\n              {%- assign feature_lines = block.settings.features | newline_to_br | split: '<br />' -%}\n              {%- for line in feature_lines -%}\n                {%- assign trimmed = line | strip -%}\n                {%- if trimmed != blank -%}\n                  <li style=\"display: flex; gap: 8px; align-items: flex-start;\"><span aria-hidden=\"true\">✓</span><span>{{ trimmed | escape }}</span></li>\n                {%- endif -%}\n              {%- endfor -%}\n            </ul>\n          {%- endif -%}\n          {%- if block.settings.ctaLabel != blank -%}\n            <a class=\"demeurer-pricing__cta\" href=\"{{ block.settings.ctaUrl | default: '#' }}\" style=\"display: inline-block; padding: 12px 24px; background: var(--demeurer-accent, #1a73e8); color: #fff; border-radius: 4px; text-decoration: none; font-weight: 600; text-align: center; margin-top: auto;\">{{ block.settings.ctaLabel | escape }}</a>\n          {%- endif -%}\n        </article>\n      {%- endfor -%}\n    </div>\n  </div>\n</section>\n\n{%- if section.settings.billingToggle -%}\n  <style>\n    .demeurer-pricing--yearly .demeurer-pricing__price-monthly { display: none; }\n    .demeurer-pricing--yearly .demeurer-pricing__price-yearly { display: inline; }\n  </style>\n  <script>\n    (function () {\n      var section = document.getElementById('shopify-section-{{ section.id }}');\n      if (!section) return;\n      var root = section.querySelector('.demeurer-pricing');\n      if (!root) return;\n      var btns = section.querySelectorAll('.demeurer-pricing__toggle-btn');\n      btns.forEach(function (btn) {\n        btn.addEventListener('click', function () {\n          var billing = btn.getAttribute('data-billing');\n          root.classList.toggle('demeurer-pricing--monthly', billing === 'monthly');\n          root.classList.toggle('demeurer-pricing--yearly', billing === 'yearly');\n          btns.forEach(function (b) { b.setAttribute('aria-pressed', String(b === btn)); });\n        });\n      });\n    })();\n  </script>\n{%- endif -%}\n\n{% schema %}\n{\n  \"blocks\": [\n    {\n      \"limit\": 5,\n      \"name\": \"Tiers\",\n      \"settings\": [\n        {\n          \"id\": \"name\",\n          \"label\": \"Tier name\",\n          \"type\": \"text\"\n        },\n        {\n          \"id\": \"description\",\n          \"label\": \"Short description\",\n          \"type\": \"textarea\"\n        },\n        {\n          \"id\": \"priceMonthly\",\n          \"label\": \"Price (monthly)\",\n          \"type\": \"textarea\"\n        },\n        {\n          \"id\": \"priceYearly\",\n          \"label\": \"Price (yearly)\",\n          \"type\": \"textarea\"\n        },\n        {\n          \"id\": \"ctaLabel\",\n          \"label\": \"CTA label\",\n          \"type\": \"textarea\"\n        },\n        {\n          \"id\": \"ctaUrl\",\n          \"label\": \"CTA link\",\n          \"type\": \"url\"\n        },\n        {\n          \"id\": \"highlighted\",\n          \"label\": \"Highlighted\",\n          \"type\": \"checkbox\"\n        },\n        {\n          \"id\": \"badge\",\n          \"label\": \"Badge (e.g. Most popular)\",\n          \"type\": \"textarea\"\n        }\n      ],\n      \"type\": \"tiers\"\n    }\n  ],\n  \"class\": \"demeurer-section demeurer-pricing\",\n  \"name\": \"Demeurer Pricing\",\n  \"presets\": [\n    {\n      \"name\": \"Demeurer Pricing\"\n    }\n  ],\n  \"settings\": [\n    {\n      \"id\": \"heading\",\n      \"label\": \"Heading\",\n      \"type\": \"textarea\"\n    },\n    {\n      \"id\": \"subheading\",\n      \"label\": \"Subheading\",\n      \"type\": \"richtext\"\n    },\n    {\n      \"id\": \"billingToggle\",\n      \"label\": \"Show monthly/yearly toggle\",\n      \"type\": \"checkbox\"\n    },\n    {\n      \"id\": \"padding_top\",\n      \"label\": \"Section padding (top)\",\n      \"type\": \"number\"\n    },\n    {\n      \"id\": \"padding_right\",\n      \"label\": \"Section padding (right)\",\n      \"type\": \"number\"\n    },\n    {\n      \"id\": \"padding_bottom\",\n      \"label\": \"Section padding (bottom)\",\n      \"type\": \"number\"\n    },\n    {\n      \"id\": \"padding_left\",\n      \"label\": \"Section padding (left)\",\n      \"type\": \"number\"\n    },\n    {\n      \"id\": \"scope_id\",\n      \"info\": \"\",\n      \"label\": \"Scope id\",\n      \"type\": \"text\"\n    },\n    {\n      \"id\": \"mobile_styles\",\n      \"info\": \"\",\n      \"label\": \"Mobile styles\",\n      \"type\": \"textarea\"\n    },\n    {\n      \"id\": \"tablet_styles\",\n      \"info\": \"\",\n      \"label\": \"Tablet styles\",\n      \"type\": \"textarea\"\n    },\n    {\n      \"id\": \"desktop_styles\",\n      \"info\": \"\",\n      \"label\": \"Desktop styles\",\n      \"type\": \"textarea\"\n    },\n    {\n      \"id\": \"visibility_styles\",\n      \"info\": \"\",\n      \"label\": \"Visibility styles\",\n      \"type\": \"textarea\"\n    }\n  ],\n  \"tag\": \"section\"\n}\n{% endschema %}\n",
        "contentHash": "696ff4089b15301f2bca42735e1ef4c2e7ae8562f55d76801605b9ff9d0d8504",
        "path": "sections/demeurer-pricing.liquid",
        "purpose": "section",
        "sectionType": "pricing"
      },
      {
        "content": "{%- liquid\n  assign scope = section.settings.scope_id | default: 'demeurer-spacer'\n-%}\n{%- style -%}\n  {{ section.settings.mobile_styles }}\n  {%- if section.settings.tablet_styles != blank -%}\n    @media (min-width: 768px) { .{{ scope }} { {{ section.settings.tablet_styles }} } }\n  {%- endif -%}\n  {%- if section.settings.desktop_styles != blank -%}\n    @media (min-width: 1280px) { .{{ scope }} { {{ section.settings.desktop_styles }} } }\n  {%- endif -%}\n  {{ section.settings.visibility_styles }}\n{%- endstyle -%}\n\n{%- liquid\n  case section.settings.dividerWidth\n    when 'medium'\n      assign thickness = 2\n    when 'thick'\n      assign thickness = 4\n    else\n      assign thickness = 1\n  endcase\n-%}\n\n<section class=\"{{ scope }} demeurer-section demeurer-spacer\" style=\"height: {{ section.settings.height }}px; display: flex; align-items: center; justify-content: center;\">\n  {%- if section.settings.showDivider -%}\n    <hr style=\"width: 100%; max-width: 1024px; margin: 0; border: 0; border-top: {{ thickness }}px solid {{ section.settings.dividerColor }};\" />\n  {%- endif -%}\n</section>\n\n{% schema %}\n{\n  \"class\": \"demeurer-section demeurer-spacer\",\n  \"name\": \"Demeurer Spacer\",\n  \"presets\": [\n    {\n      \"name\": \"Demeurer Spacer\"\n    }\n  ],\n  \"settings\": [\n    {\n      \"id\": \"height\",\n      \"label\": \"Height (px)\",\n      \"type\": \"number\"\n    },\n    {\n      \"id\": \"showDivider\",\n      \"label\": \"Show divider line\",\n      \"type\": \"checkbox\"\n    },\n    {\n      \"id\": \"dividerColor\",\n      \"label\": \"Divider color\",\n      \"type\": \"color\"\n    },\n    {\n      \"default\": \"thin\",\n      \"id\": \"dividerWidth\",\n      \"label\": \"Divider thickness\",\n      \"options\": [\n        {\n          \"label\": \"Thin\",\n          \"value\": \"thin\"\n        },\n        {\n          \"label\": \"Medium\",\n          \"value\": \"medium\"\n        },\n        {\n          \"label\": \"Thick\",\n          \"value\": \"thick\"\n        }\n      ],\n      \"type\": \"select\"\n    },\n    {\n      \"id\": \"scope_id\",\n      \"info\": \"\",\n      \"label\": \"Scope id\",\n      \"type\": \"text\"\n    },\n    {\n      \"id\": \"mobile_styles\",\n      \"info\": \"\",\n      \"label\": \"Mobile styles\",\n      \"type\": \"textarea\"\n    },\n    {\n      \"id\": \"tablet_styles\",\n      \"info\": \"\",\n      \"label\": \"Tablet styles\",\n      \"type\": \"textarea\"\n    },\n    {\n      \"id\": \"desktop_styles\",\n      \"info\": \"\",\n      \"label\": \"Desktop styles\",\n      \"type\": \"textarea\"\n    },\n    {\n      \"id\": \"visibility_styles\",\n      \"info\": \"\",\n      \"label\": \"Visibility styles\",\n      \"type\": \"textarea\"\n    }\n  ],\n  \"tag\": \"section\"\n}\n{% endschema %}\n",
        "contentHash": "224c0acd43cd90fefef121a8a6d77c6e2429a905f6570324931a73735f381c67",
        "path": "sections/demeurer-spacer.liquid",
        "purpose": "section",
        "sectionType": "spacer"
      },
      {
        "content": "{%- liquid\n  assign scope = section.settings.scope_id | default: 'demeurer-testimonial'\n-%}\n{%- style -%}\n  {{ section.settings.mobile_styles }}\n  {%- if section.settings.tablet_styles != blank -%}\n    @media (min-width: 768px) { .{{ scope }} { {{ section.settings.tablet_styles }} } }\n  {%- endif -%}\n  {%- if section.settings.desktop_styles != blank -%}\n    @media (min-width: 1280px) { .{{ scope }} { {{ section.settings.desktop_styles }} } }\n  {%- endif -%}\n  {{ section.settings.visibility_styles }}\n{%- endstyle -%}\n\n<section class=\"{{ scope }} demeurer-section demeurer-testimonial\">\n  <div class=\"demeurer-testimonial__inner\" style=\"max-width: 1200px; margin-inline: auto;\">\n    {%- if section.settings.heading != blank -%}\n      <h2 class=\"demeurer-testimonial__heading\" style=\"text-align: center; margin: 0 0 32px;\">{{ section.settings.heading | escape }}</h2>\n    {%- endif -%}\n\n    {%- if section.settings.layout == 'carousel' -%}\n      <div class=\"demeurer-testimonial__carousel\" style=\"display: flex; gap: 24px; overflow-x: auto; scroll-snap-type: x mandatory; padding-bottom: 12px;\">\n        {%- for block in section.blocks -%}\n          <article class=\"demeurer-testimonial__card\" {{ block.shopify_attributes }} style=\"flex: 0 0 80%; scroll-snap-align: start; padding: 24px; background: #fafafa; border-radius: 8px;\">\n            {%- if block.settings.quote != blank -%}\n              <blockquote class=\"demeurer-testimonial__quote\" style=\"margin: 0; font-size: 1.1rem; line-height: 1.5;\">{{ block.settings.quote }}</blockquote>\n            {%- endif -%}\n            <footer class=\"demeurer-testimonial__footer\" style=\"margin-top: 16px; display: flex; gap: 12px; align-items: center;\">\n              {%- if block.settings.authorImage != blank -%}\n                {{ block.settings.authorImage | image_url: width: 80 | image_tag: width: 40, height: 40, loading: 'lazy', alt: block.settings.authorName, style: 'border-radius: 50%; object-fit: cover;' }}\n              {%- endif -%}\n              <div>\n                {%- if block.settings.authorName != blank -%}\n                  <div style=\"font-weight: 600;\">{{ block.settings.authorName | escape }}</div>\n                {%- endif -%}\n                {%- if block.settings.authorTitle != blank -%}\n                  <div style=\"opacity: 0.7; font-size: 0.9em;\">{{ block.settings.authorTitle | escape }}</div>\n                {%- endif -%}\n              </div>\n            </footer>\n          </article>\n        {%- endfor -%}\n      </div>\n    {%- elsif section.settings.layout == 'grid' -%}\n      <div class=\"demeurer-testimonial__grid\" style=\"display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 24px;\">\n        {%- for block in section.blocks -%}\n          <article class=\"demeurer-testimonial__card\" {{ block.shopify_attributes }} style=\"padding: 24px; background: #fafafa; border-radius: 8px;\">\n            {%- if block.settings.quote != blank -%}\n              <blockquote class=\"demeurer-testimonial__quote\" style=\"margin: 0; line-height: 1.5;\">{{ block.settings.quote }}</blockquote>\n            {%- endif -%}\n            <footer class=\"demeurer-testimonial__footer\" style=\"margin-top: 16px; display: flex; gap: 12px; align-items: center;\">\n              {%- if block.settings.authorImage != blank -%}\n                {{ block.settings.authorImage | image_url: width: 80 | image_tag: width: 40, height: 40, loading: 'lazy', alt: block.settings.authorName, style: 'border-radius: 50%; object-fit: cover;' }}\n              {%- endif -%}\n              <div>\n                {%- if block.settings.authorName != blank -%}\n                  <div style=\"font-weight: 600;\">{{ block.settings.authorName | escape }}</div>\n                {%- endif -%}\n                {%- if block.settings.authorTitle != blank -%}\n                  <div style=\"opacity: 0.7; font-size: 0.9em;\">{{ block.settings.authorTitle | escape }}</div>\n                {%- endif -%}\n              </div>\n            </footer>\n          </article>\n        {%- endfor -%}\n      </div>\n    {%- else -%}\n      {%- assign first = section.blocks | first -%}\n      {%- if first -%}\n        <article class=\"demeurer-testimonial__single\" style=\"max-width: 720px; margin-inline: auto; text-align: center;\">\n          {%- if first.settings.quote != blank -%}\n            <blockquote class=\"demeurer-testimonial__quote\" style=\"margin: 0; font-size: 1.25rem; line-height: 1.5;\">{{ first.settings.quote }}</blockquote>\n          {%- endif -%}\n          <footer class=\"demeurer-testimonial__footer\" style=\"margin-top: 24px;\">\n            {%- if first.settings.authorImage != blank -%}\n              {{ first.settings.authorImage | image_url: width: 96 | image_tag: width: 48, height: 48, loading: 'lazy', alt: first.settings.authorName, style: 'border-radius: 50%; object-fit: cover; margin-inline: auto; display: block;' }}\n            {%- endif -%}\n            {%- if first.settings.authorName != blank -%}\n              <div style=\"font-weight: 600; margin-top: 12px;\">{{ first.settings.authorName | escape }}</div>\n            {%- endif -%}\n            {%- if first.settings.authorTitle != blank -%}\n              <div style=\"opacity: 0.7; font-size: 0.9em;\">{{ first.settings.authorTitle | escape }}</div>\n            {%- endif -%}\n          </footer>\n        </article>\n      {%- endif -%}\n    {%- endif -%}\n  </div>\n</section>\n\n{% schema %}\n{\n  \"blocks\": [\n    {\n      \"limit\": 6,\n      \"name\": \"Testimonials\",\n      \"settings\": [\n        {\n          \"id\": \"quote\",\n          \"label\": \"Quote\",\n          \"type\": \"richtext\"\n        },\n        {\n          \"id\": \"authorName\",\n          \"label\": \"Author name\",\n          \"type\": \"text\"\n        },\n        {\n          \"id\": \"authorTitle\",\n          \"label\": \"Author title\",\n          \"type\": \"text\"\n        },\n        {\n          \"id\": \"authorImage\",\n          \"label\": \"Author photo\",\n          \"type\": \"image_picker\"\n        },\n        {\n          \"id\": \"rating\",\n          \"label\": \"Rating (0–5)\",\n          \"type\": \"number\"\n        }\n      ],\n      \"type\": \"testimonials\"\n    }\n  ],\n  \"class\": \"demeurer-section demeurer-testimonial\",\n  \"name\": \"Demeurer Testimonial\",\n  \"presets\": [\n    {\n      \"name\": \"Demeurer Testimonial\"\n    }\n  ],\n  \"settings\": [\n    {\n      \"id\": \"heading\",\n      \"label\": \"Heading\",\n      \"type\": \"textarea\"\n    },\n    {\n      \"default\": \"single\",\n      \"id\": \"layout\",\n      \"label\": \"Layout\",\n      \"options\": [\n        {\n          \"label\": \"Single\",\n          \"value\": \"single\"\n        },\n        {\n          \"label\": \"Carousel\",\n          \"value\": \"carousel\"\n        },\n        {\n          \"label\": \"Grid\",\n          \"value\": \"grid\"\n        }\n      ],\n      \"type\": \"select\"\n    },\n    {\n      \"id\": \"padding_top\",\n      \"label\": \"Section padding (top)\",\n      \"type\": \"number\"\n    },\n    {\n      \"id\": \"padding_right\",\n      \"label\": \"Section padding (right)\",\n      \"type\": \"number\"\n    },\n    {\n      \"id\": \"padding_bottom\",\n      \"label\": \"Section padding (bottom)\",\n      \"type\": \"number\"\n    },\n    {\n      \"id\": \"padding_left\",\n      \"label\": \"Section padding (left)\",\n      \"type\": \"number\"\n    },\n    {\n      \"id\": \"scope_id\",\n      \"info\": \"\",\n      \"label\": \"Scope id\",\n      \"type\": \"text\"\n    },\n    {\n      \"id\": \"mobile_styles\",\n      \"info\": \"\",\n      \"label\": \"Mobile styles\",\n      \"type\": \"textarea\"\n    },\n    {\n      \"id\": \"tablet_styles\",\n      \"info\": \"\",\n      \"label\": \"Tablet styles\",\n      \"type\": \"textarea\"\n    },\n    {\n      \"id\": \"desktop_styles\",\n      \"info\": \"\",\n      \"label\": \"Desktop styles\",\n      \"type\": \"textarea\"\n    },\n    {\n      \"id\": \"visibility_styles\",\n      \"info\": \"\",\n      \"label\": \"Visibility styles\",\n      \"type\": \"textarea\"\n    }\n  ],\n  \"tag\": \"section\"\n}\n{% endschema %}\n",
        "contentHash": "1b06edc6fa40925f9d748c7af52390d63c1235c98ce6a7bf0f6b3bed86177c9e",
        "path": "sections/demeurer-testimonial.liquid",
        "purpose": "section",
        "sectionType": "testimonial"
      },
      {
        "content": "{%- liquid\n  assign scope = section.settings.scope_id | default: 'demeurer-video'\n-%}\n{%- style -%}\n  {{ section.settings.mobile_styles }}\n  {%- if section.settings.tablet_styles != blank -%}\n    @media (min-width: 768px) { .{{ scope }} { {{ section.settings.tablet_styles }} } }\n  {%- endif -%}\n  {%- if section.settings.desktop_styles != blank -%}\n    @media (min-width: 1280px) { .{{ scope }} { {{ section.settings.desktop_styles }} } }\n  {%- endif -%}\n  {{ section.settings.visibility_styles }}\n{%- endstyle -%}\n\n{%- liquid\n  assign url = section.settings.videoUrl\n  assign ratio = section.settings.aspectRatio | default: '16:9'\n  assign aspect = ratio | replace: ':', ' / '\n-%}\n\n<section class=\"{{ scope }} demeurer-section demeurer-video\">\n  <div class=\"demeurer-video__inner\" style=\"max-width: 1200px; margin-inline: auto;\">\n    {%- if section.settings.heading != blank -%}\n      <h2 class=\"demeurer-video__heading\" style=\"margin: 0 0 24px; text-align: center;\">{{ section.settings.heading | escape }}</h2>\n    {%- endif -%}\n    {%- if section.settings.subheading != blank -%}\n      <div class=\"demeurer-video__subheading\" style=\"margin: 0 0 24px; text-align: center; opacity: 0.75;\">{{ section.settings.subheading }}</div>\n    {%- endif -%}\n\n    {%- if url != blank -%}\n      <div class=\"demeurer-video__frame\" style=\"position: relative; aspect-ratio: {{ aspect }}; max-width: 1024px; margin-inline: auto; border-radius: 8px; overflow: hidden; background: #000;\">\n        {%- if url contains 'youtube.com' or url contains 'youtu.be' -%}\n          {%- assign yt_id = url | split: 'v=' | last | split: '&' | first -%}\n          {%- if url contains 'youtu.be/' -%}\n            {%- assign yt_id = url | split: 'youtu.be/' | last | split: '?' | first -%}\n          {%- endif -%}\n          <iframe\n            src=\"https://www.youtube-nocookie.com/embed/{{ yt_id }}{%- if section.settings.autoplay -%}?autoplay=1&mute=1&playsinline=1{%- endif -%}\"\n            title=\"{{ section.settings.heading | default: 'Video' | escape }}\"\n            loading=\"lazy\"\n            referrerpolicy=\"strict-origin-when-cross-origin\"\n            allow=\"accelerometer; autoplay; encrypted-media; picture-in-picture\"\n            allowfullscreen\n            style=\"position: absolute; inset: 0; width: 100%; height: 100%; border: 0;\"></iframe>\n        {%- elsif url contains 'vimeo.com' -%}\n          {%- assign vimeo_id = url | split: 'vimeo.com/' | last | split: '?' | first -%}\n          <iframe\n            src=\"https://player.vimeo.com/video/{{ vimeo_id }}{%- if section.settings.autoplay -%}?autoplay=1&muted=1&playsinline=1{%- endif -%}\"\n            title=\"{{ section.settings.heading | default: 'Video' | escape }}\"\n            loading=\"lazy\"\n            referrerpolicy=\"strict-origin-when-cross-origin\"\n            allow=\"autoplay; fullscreen; picture-in-picture\"\n            allowfullscreen\n            style=\"position: absolute; inset: 0; width: 100%; height: 100%; border: 0;\"></iframe>\n        {%- else -%}\n          <video\n            src=\"{{ url }}\"\n            {% if section.settings.showControls %}controls{% endif %}\n            {% if section.settings.autoplay %}autoplay playsinline{% endif %}\n            {% if section.settings.muted %}muted{% endif %}\n            preload=\"metadata\"\n            style=\"position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover;\">\n          </video>\n        {%- endif -%}\n      </div>\n    {%- else -%}\n      <div class=\"demeurer-video__placeholder\" style=\"aspect-ratio: {{ aspect }}; max-width: 1024px; margin-inline: auto; background: #f3f4f6; border-radius: 8px; display: grid; place-items: center; opacity: 0.7;\">No video URL set</div>\n    {%- endif -%}\n  </div>\n</section>\n\n{% schema %}\n{\n  \"class\": \"demeurer-section demeurer-video\",\n  \"name\": \"Demeurer Video\",\n  \"presets\": [\n    {\n      \"name\": \"Demeurer Video\"\n    }\n  ],\n  \"settings\": [\n    {\n      \"id\": \"heading\",\n      \"label\": \"Heading\",\n      \"type\": \"textarea\"\n    },\n    {\n      \"id\": \"subheading\",\n      \"label\": \"Subheading\",\n      \"type\": \"richtext\"\n    },\n    {\n      \"id\": \"videoUrl\",\n      \"label\": \"Video URL (YouTube, Vimeo, or .mp4)\",\n      \"type\": \"url\"\n    },\n    {\n      \"default\": \"16:9\",\n      \"id\": \"aspectRatio\",\n      \"label\": \"Aspect ratio\",\n      \"options\": [\n        {\n          \"label\": \"16:9 (widescreen)\",\n          \"value\": \"16:9\"\n        },\n        {\n          \"label\": \"4:3 (classic)\",\n          \"value\": \"4:3\"\n        },\n        {\n          \"label\": \"1:1 (square)\",\n          \"value\": \"1:1\"\n        },\n        {\n          \"label\": \"9:16 (vertical)\",\n          \"value\": \"9:16\"\n        }\n      ],\n      \"type\": \"select\"\n    },\n    {\n      \"id\": \"showControls\",\n      \"label\": \"Show controls\",\n      \"type\": \"checkbox\"\n    },\n    {\n      \"id\": \"autoplay\",\n      \"label\": \"Autoplay (muted only)\",\n      \"type\": \"checkbox\"\n    },\n    {\n      \"id\": \"muted\",\n      \"label\": \"Start muted\",\n      \"type\": \"checkbox\"\n    },\n    {\n      \"id\": \"padding_top\",\n      \"label\": \"Section padding (top)\",\n      \"type\": \"number\"\n    },\n    {\n      \"id\": \"padding_right\",\n      \"label\": \"Section padding (right)\",\n      \"type\": \"number\"\n    },\n    {\n      \"id\": \"padding_bottom\",\n      \"label\": \"Section padding (bottom)\",\n      \"type\": \"number\"\n    },\n    {\n      \"id\": \"padding_left\",\n      \"label\": \"Section padding (left)\",\n      \"type\": \"number\"\n    },\n    {\n      \"id\": \"scope_id\",\n      \"info\": \"\",\n      \"label\": \"Scope id\",\n      \"type\": \"text\"\n    },\n    {\n      \"id\": \"mobile_styles\",\n      \"info\": \"\",\n      \"label\": \"Mobile styles\",\n      \"type\": \"textarea\"\n    },\n    {\n      \"id\": \"tablet_styles\",\n      \"info\": \"\",\n      \"label\": \"Tablet styles\",\n      \"type\": \"textarea\"\n    },\n    {\n      \"id\": \"desktop_styles\",\n      \"info\": \"\",\n      \"label\": \"Desktop styles\",\n      \"type\": \"textarea\"\n    },\n    {\n      \"id\": \"visibility_styles\",\n      \"info\": \"\",\n      \"label\": \"Visibility styles\",\n      \"type\": \"textarea\"\n    }\n  ],\n  \"tag\": \"section\"\n}\n{% endschema %}\n",
        "contentHash": "343671ff26b53082cc565491e8338b8221b44bb565a973c91fb9591d4d338690",
        "path": "sections/demeurer-video.liquid",
        "purpose": "section",
        "sectionType": "video"
      },
      {
        "content": "{\n  \"order\": [\n    \"main-blk_hero\",\n    \"main-blk_ctab\",\n    \"main-blk_imgt\",\n    \"main-blk_feat\",\n    \"main-blk_logo\",\n    \"main-blk_test\",\n    \"main-blk_faq_\",\n    \"main-blk_pric\",\n    \"main-blk_vidd\",\n    \"main-blk_form\",\n    \"main-blk_spac\",\n    \"main-blk_html\"\n  ],\n  \"sections\": {\n    \"main-blk_ctab\": {\n      \"settings\": {\n        \"alignment\": \"center\",\n        \"background\": \"#1a1a1a\",\n        \"ctaLabel\": \"Sign up\",\n        \"ctaUrl\": \"/account/register\",\n        \"desktop_styles\": \"\",\n        \"heading\": \"Ready to get started?\",\n        \"mobile_styles\": \".demeurer-cta-band-blk_ctab_dddddddd {\\n  padding: 0;\\n  text-align: center;\\n  background: #1a1a1a;\\n}\",\n        \"padding_bottom\": 64,\n        \"padding_left\": 24,\n        \"padding_right\": 24,\n        \"padding_top\": 64,\n        \"scope_id\": \"demeurer-cta-band-blk_ctab_dddddddd\",\n        \"secondaryCtaLabel\": \"\",\n        \"secondaryCtaUrl\": \"\",\n        \"subheading\": \"<p>Free shipping on your first order. No surprises at checkout.</p>\",\n        \"tablet_styles\": \"\",\n        \"visibility_styles\": \"\"\n      },\n      \"type\": \"demeurer-cta-band\"\n    },\n    \"main-blk_faq_\": {\n      \"block_order\": [\n        \"questions-0\",\n        \"questions-1\",\n        \"questions-2\"\n      ],\n      \"blocks\": {\n        \"questions-0\": {\n          \"settings\": {\n            \"answer\": \"<p>Standard orders ship within one business day and typically arrive within 3–5 business days in the continental US.</p>\",\n            \"question\": \"How long does shipping take?\"\n          },\n          \"type\": \"questions\"\n        },\n        \"questions-1\": {\n          \"settings\": {\n            \"answer\": \"<p>You can return any unworn item within 30 days for a full refund. Returns are free in the US.</p>\",\n            \"question\": \"What's your return policy?\"\n          },\n          \"type\": \"questions\"\n        },\n        \"questions-2\": {\n          \"settings\": {\n            \"answer\": \"<p>Yes — email <a href=\\\"mailto:hi@example.com\\\">hi@example.com</a> within an hour of ordering and we'll do our best.</p>\",\n            \"question\": \"Can I change my order after placing it?\"\n          },\n          \"type\": \"questions\"\n        }\n      },\n      \"settings\": {\n        \"alignment\": \"left\",\n        \"desktop_styles\": \"\",\n        \"heading\": \"Frequently asked questions\",\n        \"mobile_styles\": \".demeurer-faq-blk_faq_iiiiiiii {\\n  padding: 0;\\n  text-align: center;\\n}\",\n        \"padding_bottom\": 64,\n        \"padding_left\": 24,\n        \"padding_right\": 24,\n        \"padding_top\": 64,\n        \"scope_id\": \"demeurer-faq-blk_faq_iiiiiiii\",\n        \"tablet_styles\": \"\",\n        \"visibility_styles\": \"\"\n      },\n      \"type\": \"demeurer-faq\"\n    },\n    \"main-blk_feat\": {\n      \"block_order\": [\n        \"features-0\",\n        \"features-1\",\n        \"features-2\"\n      ],\n      \"blocks\": {\n        \"features-0\": {\n          \"settings\": {\n            \"description\": \"<p>Orders placed before 2pm ship the same day from our warehouse.</p>\",\n            \"icon\": \"Zap\",\n            \"title\": \"Fast shipping\"\n          },\n          \"type\": \"features\"\n        },\n        \"features-1\": {\n          \"settings\": {\n            \"description\": \"<p>Not the right fit? Send it back within 30 days for a full refund.</p>\",\n            \"icon\": \"Shield\",\n            \"title\": \"30-day returns\"\n          },\n          \"type\": \"features\"\n        },\n        \"features-2\": {\n          \"settings\": {\n            \"description\": \"<p>Every product is sourced from makers we've worked with for years.</p>\",\n            \"icon\": \"Heart\",\n            \"title\": \"Made with care\"\n          },\n          \"type\": \"features\"\n        }\n      },\n      \"settings\": {\n        \"alignment\": \"left\",\n        \"desktop_styles\": \"\",\n        \"heading\": \"Why choose us\",\n        \"layout\": \"grid-3\",\n        \"mobile_styles\": \".demeurer-feature-list-blk_feat_ffffffff {\\n  padding: 0;\\n  text-align: center;\\n}\",\n        \"padding_bottom\": 64,\n        \"padding_left\": 24,\n        \"padding_right\": 24,\n        \"padding_top\": 64,\n        \"scope_id\": \"demeurer-feature-list-blk_feat_ffffffff\",\n        \"subheading\": \"\",\n        \"tablet_styles\": \"\",\n        \"visibility_styles\": \"\"\n      },\n      \"type\": \"demeurer-feature-list\"\n    },\n    \"main-blk_form\": {\n      \"block_order\": [\n        \"fields-0\",\n        \"fields-1\",\n        \"fields-2\"\n      ],\n      \"blocks\": {\n        \"fields-0\": {\n          \"settings\": {\n            \"kind\": \"text\",\n            \"label\": \"Your name\",\n            \"name\": \"name\",\n            \"options\": \"\",\n            \"required\": true\n          },\n          \"type\": \"fields\"\n        },\n        \"fields-1\": {\n          \"settings\": {\n            \"kind\": \"email\",\n            \"label\": \"Email\",\n            \"name\": \"email\",\n            \"options\": \"\",\n            \"required\": true\n          },\n          \"type\": \"fields\"\n        },\n        \"fields-2\": {\n          \"settings\": {\n            \"kind\": \"textarea\",\n            \"label\": \"Message\",\n            \"name\": \"body\",\n            \"options\": \"\",\n            \"required\": true\n          },\n          \"type\": \"fields\"\n        }\n      },\n      \"settings\": {\n        \"desktop_styles\": \"\",\n        \"formType\": \"contact\",\n        \"heading\": \"Get in touch\",\n        \"mobile_styles\": \".demeurer-form-blk_form_llllllll {\\n  padding: 0;\\n}\",\n        \"padding_bottom\": 64,\n        \"padding_left\": 24,\n        \"padding_right\": 24,\n        \"padding_top\": 64,\n        \"scope_id\": \"demeurer-form-blk_form_llllllll\",\n        \"subheading\": \"<p>We usually respond within a day.</p>\",\n        \"submitLabel\": \"Send\",\n        \"successMessage\": \"<p>Thanks — we'll be in touch shortly.</p>\",\n        \"tablet_styles\": \"\",\n        \"visibility_styles\": \"\"\n      },\n      \"type\": \"demeurer-form\"\n    },\n    \"main-blk_hero\": {\n      \"settings\": {\n        \"alignment\": \"center\",\n        \"backgroundImage\": \"\",\n        \"bound_variant_ids\": \"\",\n        \"ctaLabel\": \"Shop now\",\n        \"ctaUrl\": \"/collections/all\",\n        \"desktop_styles\": \"\",\n        \"heading\": \"Welcome to your store\",\n        \"mobile_styles\": \".demeurer-hero-blk_hero_cccccccc {\\n  padding: 0;\\n  text-align: center;\\n}\",\n        \"overlayColor\": \"#00000040\",\n        \"padding_bottom\": 96,\n        \"padding_left\": 24,\n        \"padding_right\": 24,\n        \"padding_top\": 96,\n        \"scope_id\": \"demeurer-hero-blk_hero_cccccccc\",\n        \"subheading\": \"<p>Your subheading here</p>\",\n        \"tablet_styles\": \"\",\n        \"visibility_styles\": \"\"\n      },\n      \"type\": \"demeurer-hero\"\n    },\n    \"main-blk_html\": {\n      \"settings\": {\n        \"desktop_styles\": \"\",\n        \"html\": \"<p>Hand-rolled markup.</p>\",\n        \"mobile_styles\": \".demeurer-html-blk_html_nnnnnnnn {\\n  padding: 0;\\n}\",\n        \"notes\": \"\",\n        \"padding_bottom\": 32,\n        \"padding_left\": 24,\n        \"padding_right\": 24,\n        \"padding_top\": 32,\n        \"scope_id\": \"demeurer-html-blk_html_nnnnnnnn\",\n        \"tablet_styles\": \"\",\n        \"visibility_styles\": \"\"\n      },\n      \"type\": \"demeurer-html\"\n    },\n    \"main-blk_imgt\": {\n      \"settings\": {\n        \"body\": \"<p>We started in a one-bedroom apartment with a sewing machine and a vision. Today, our pieces are worn in over thirty countries — but the makers, the materials, and the obsession with detail are exactly the same.</p>\",\n        \"bound_variant_ids\": \"\",\n        \"ctaLabel\": \"\",\n        \"ctaUrl\": \"\",\n        \"desktop_styles\": \"\",\n        \"heading\": \"Our story\",\n        \"image\": \"\",\n        \"imageAlt\": \"\",\n        \"imagePosition\": \"left\",\n        \"imageWidth\": \"50\",\n        \"mobile_styles\": \".demeurer-image-text-blk_imgt_eeeeeeee {\\n  padding: 0;\\n}\",\n        \"padding_bottom\": 64,\n        \"padding_left\": 24,\n        \"padding_right\": 24,\n        \"padding_top\": 64,\n        \"scope_id\": \"demeurer-image-text-blk_imgt_eeeeeeee\",\n        \"tablet_styles\": \"\",\n        \"visibility_styles\": \"\"\n      },\n      \"type\": \"demeurer-image-text\"\n    },\n    \"main-blk_logo\": {\n      \"settings\": {\n        \"desktop_styles\": \"\",\n        \"heading\": \"Trusted by\",\n        \"layout\": \"grid\",\n        \"logoSize\": \"medium\",\n        \"mobile_styles\": \".demeurer-logo-wall-blk_logo_gggggggg {\\n  padding: 0;\\n}\",\n        \"padding_bottom\": 56,\n        \"padding_left\": 24,\n        \"padding_right\": 24,\n        \"padding_top\": 56,\n        \"scope_id\": \"demeurer-logo-wall-blk_logo_gggggggg\",\n        \"tablet_styles\": \"\",\n        \"visibility_styles\": \"\"\n      },\n      \"type\": \"demeurer-logo-wall\"\n    },\n    \"main-blk_pric\": {\n      \"block_order\": [\n        \"tiers-0\",\n        \"tiers-1\",\n        \"tiers-2\"\n      ],\n      \"blocks\": {\n        \"tiers-0\": {\n          \"settings\": {\n            \"badge\": \"\",\n            \"ctaLabel\": \"Get started\",\n            \"ctaUrl\": \"/account/register\",\n            \"description\": \"Try the basics, forever.\",\n            \"features\": \"1 page\\nCommunity support\",\n            \"highlighted\": false,\n            \"name\": \"Free\",\n            \"priceMonthly\": \"$0\",\n            \"priceYearly\": \"$0\"\n          },\n          \"type\": \"tiers\"\n        },\n        \"tiers-1\": {\n          \"settings\": {\n            \"badge\": \"Most popular\",\n            \"ctaLabel\": \"Start free trial\",\n            \"ctaUrl\": \"/pages/checkout\",\n            \"description\": \"Everything most stores need.\",\n            \"features\": \"Unlimited pages\\nEmail support\\nBasic analytics\",\n            \"highlighted\": true,\n            \"name\": \"Starter\",\n            \"priceMonthly\": \"$19\",\n            \"priceYearly\": \"$190\"\n          },\n          \"type\": \"tiers\"\n        },\n        \"tiers-2\": {\n          \"settings\": {\n            \"badge\": \"\",\n            \"ctaLabel\": \"Talk to sales\",\n            \"ctaUrl\": \"/pages/contact\",\n            \"description\": \"Scale with confidence.\",\n            \"features\": \"Everything in Starter\\nPriority support\\nAdvanced analytics\\nCustom domain\",\n            \"highlighted\": false,\n            \"name\": \"Pro\",\n            \"priceMonthly\": \"$49\",\n            \"priceYearly\": \"$490\"\n          },\n          \"type\": \"tiers\"\n        }\n      },\n      \"settings\": {\n        \"billingToggle\": false,\n        \"desktop_styles\": \"\",\n        \"heading\": \"Simple pricing\",\n        \"mobile_styles\": \".demeurer-pricing-blk_pric_jjjjjjjj {\\n  padding: 0;\\n}\",\n        \"padding_bottom\": 80,\n        \"padding_left\": 24,\n        \"padding_right\": 24,\n        \"padding_top\": 80,\n        \"scope_id\": \"demeurer-pricing-blk_pric_jjjjjjjj\",\n        \"subheading\": \"<p>Pick the plan that fits — change anytime.</p>\",\n        \"tablet_styles\": \"\",\n        \"visibility_styles\": \"\"\n      },\n      \"type\": \"demeurer-pricing\"\n    },\n    \"main-blk_spac\": {\n      \"settings\": {\n        \"desktop_styles\": \"\",\n        \"dividerColor\": \"#e5e7eb\",\n        \"dividerWidth\": \"thin\",\n        \"height\": 48,\n        \"mobile_styles\": \"\",\n        \"scope_id\": \"demeurer-spacer-blk_spac_mmmmmmmm\",\n        \"showDivider\": false,\n        \"tablet_styles\": \"\",\n        \"visibility_styles\": \"\"\n      },\n      \"type\": \"demeurer-spacer\"\n    },\n    \"main-blk_test\": {\n      \"block_order\": [\n        \"testimonials-0\",\n        \"testimonials-1\"\n      ],\n      \"blocks\": {\n        \"testimonials-0\": {\n          \"settings\": {\n            \"authorImage\": \"\",\n            \"authorName\": \"Maya R.\",\n            \"authorTitle\": \"Verified buyer\",\n            \"quote\": \"<p>The fit is exactly what I'd been searching for. I bought one in every color and they've held up beautifully wash after wash.</p>\",\n            \"rating\": 5\n          },\n          \"type\": \"testimonials\"\n        },\n        \"testimonials-1\": {\n          \"settings\": {\n            \"authorImage\": \"\",\n            \"authorName\": \"Daniel K.\",\n            \"authorTitle\": \"Verified buyer\",\n            \"quote\": \"<p>Customer service walked me through sizing on a Sunday evening. That kind of attention has stopped being normal — I appreciate it.</p>\",\n            \"rating\": 5\n          },\n          \"type\": \"testimonials\"\n        }\n      },\n      \"settings\": {\n        \"desktop_styles\": \"\",\n        \"heading\": \"What customers are saying\",\n        \"layout\": \"single\",\n        \"mobile_styles\": \".demeurer-testimonial-blk_test_hhhhhhhh {\\n  padding: 0;\\n}\",\n        \"padding_bottom\": 64,\n        \"padding_left\": 24,\n        \"padding_right\": 24,\n        \"padding_top\": 64,\n        \"scope_id\": \"demeurer-testimonial-blk_test_hhhhhhhh\",\n        \"tablet_styles\": \"\",\n        \"visibility_styles\": \"\"\n      },\n      \"type\": \"demeurer-testimonial\"\n    },\n    \"main-blk_vidd\": {\n      \"settings\": {\n        \"aspectRatio\": \"16:9\",\n        \"autoplay\": false,\n        \"desktop_styles\": \"\",\n        \"heading\": \"\",\n        \"mobile_styles\": \".demeurer-video-blk_vidd_kkkkkkkk {\\n  padding: 0;\\n}\",\n        \"muted\": true,\n        \"padding_bottom\": 64,\n        \"padding_left\": 24,\n        \"padding_right\": 24,\n        \"padding_top\": 64,\n        \"scope_id\": \"demeurer-video-blk_vidd_kkkkkkkk\",\n        \"showControls\": true,\n        \"subheading\": \"\",\n        \"tablet_styles\": \"\",\n        \"videoUrl\": \"\",\n        \"visibility_styles\": \"\"\n      },\n      \"type\": \"demeurer-video\"\n    }\n  }\n}\n",
